fig.hard_points, cls: 'badge-hard' },\r\n              ].map(({ label, points, cls }) => (\r\n                <div key={label} className={`flex flex-col items-center gap-2 px-6 py-4 rounded-2xl ${cls}`}>\r\n                  <span className=\"text-sm font-bold\">{label}</span>\r\n                  <span className=\"text-3xl font-black\">+{points}</span>\r\n                  <span className=\"text-xs\">в”ҳГҘв”ҳГ©в•Әв•–в•ӘвҢҗ</span>\r\n                </div>\r\n              ))}\r\n            </div>\r\n            <p className=\"text-center text-sm mt-4\" style={{ color: 'var(--color-text-muted)' }}>\r\n              О“Г…в–’вҲ©в••Г… в”ҳГӘв”ҳГ©в•ӘВ¬ в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв•ӘВәв•ӘВҝв•ӘвҢҗ: {config.default_timer_seconds} в•ӘВҪв•ӘВәв”ҳГҘв”ҳГЁв•ӘвҢҗ\r\n            </p>\r\n          </div>\r\n\r\n          <button onClick={save} disabled={saving} className=\"btn btn-primary btn-lg w-full\">\r\n            {saving ? 'в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•ӘВЎв”ҳГјв•Әв••...' : 'в•ӘВЎв”ҳГјв•Әв•• в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬'}\r\n          </button>\r\n        </div>\r\n      )}\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\app\\admin\\sessions\\page.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'supabase'. Either include it or remove the dependency array.","line":24,"column":6,"nodeType":"ArrayExpression","endLine":24,"endColumn":8,"suggestions":[{"desc":"Update the dependencies array to be: [supabase]","fix":{"range":[742,744],"text":"[supabase]"}}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":73,"column":44,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":73,"endColumn":47,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[3001,3004],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[3001,3004],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useState } from 'react'\r\nimport { createClient } from '@/lib/supabaseClient'\r\nimport toast from 'react-hot-toast'\r\nimport { SessionWithDetails } from '@/types/admin'\r\n\r\nexport default function AdminSessionsPage() {\r\n  const supabase = createClient()\r\n  const [sessions, setSessions] = useState<SessionWithDetails[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n\r\n  useEffect(() => {\r\n    async function load() {\r\n      const { data } = await supabase\r\n        .from('sessions')\r\n        .select(`*, teams(id,name,score,color), profiles(email)`)\r\n        .order('created_at', { ascending: false })\r\n        .limit(50)\r\n      setSessions(data ?? [])\r\n      setLoading(false)\r\n    }\r\n    load()\r\n  }, [])\r\n\r\n  const stateColor = (s: string) =>\r\n    s === 'playing' ? '#10b981' : s === 'finished' ? 'var(--color-text-muted)' : 'var(--color-accent)'\r\n  const stateLabel = (s: string) =>\r\n    s === 'playing' ? 'О“ГңГӯ в”ҳГЁв”ҳГӨв•Әв•Јв•ӘВҝ' : s === 'finished' ? 'О“ВЈГҙ в”ҳГ в”ҳГҘв•ӘВ¬в”ҳГ§в”ҳГЁ' : 'О“Г…в”Ӯ в”ҳГӨв”ҳГӘв•ӘВҝв”ҳГЁ'\r\n\r\n  return (\r\n    <div className=\"p-8\">\r\n      <div className=\"mb-8\">\r\n        <h1 className=\"text-3xl font-black gradient-text-primary\">в•ӘВәв”ҳГӨв•ӘВјв”ҳГӨв•Әв”Ӯв•ӘВәв•ӘВ¬</h1>\r\n        <p style={{ color: 'var(--color-text-secondary)' }}>в•ӘГів•ӘВ«в•Әв–’ 50 в•ӘВјв”ҳГӨв•Әв”Ӯв•ӘвҢҗ</p>\r\n      </div>\r\n\r\n      {loading ? (\r\n        <div className=\"space-y-3\">\r\n          {Array(8).fill(0).map((_, i) => <div key={i} className=\"h-20 card-glass animate-shimmer rounded-xl\" />)}\r\n        </div>\r\n      ) : (\r\n        <div className=\"space-y-3\">\r\n          {sessions.map(s => {\r\n            const topTeam = [...(s.teams ?? [])].sort((a, b) => b.score - a.score)[0]\r\n            return (\r\n              <div key={s.id} className=\"card-glass flex items-center gap-6 p-4\">\r\n                {/* Mode */}\r\n                <div className=\"text-2xl shrink-0\">{s.mode === 'remote' ? 'вүЎЖ’Г®Гү' : 'вүЎЖ’Г…ГЎ'}</div>\r\n\r\n                {/* Info */}\r\n                <div className=\"flex-1 min-w-0\">\r\n                  <div className=\"flex items-center gap-2 mb-1\">\r\n                    <span className=\"font-mono text-xs\" style={{ color: 'var(--color-text-muted)' }}>\r\n                      {s.id}\r\n                    </span>\r\n                    {s.join_code && (\r\n                      <span className=\"font-mono text-xs px-2 py-0.5 rounded\" style={{ background: 'var(--color-surface-3)', color: 'var(--color-accent)' }}>\r\n                        {s.join_code}\r\n                      </span>\r\n                    )}\r\n                    <span className=\"text-xs font-bold\" style={{ color: stateColor(s.state) }}>\r\n                      {stateLabel(s.state)}\r\n                    </span>\r\n                  </div>\r\n                  <p className=\"text-xs\" style={{ color: 'var(--color-text-muted)' }}>\r\n                    {s.profiles?.email ?? 'в”ҳГ в•ӘВјв”ҳГ§в”ҳГӘв”ҳГӨ'} в”¬в•– {new Date(s.created_at).toLocaleString('ar-SA')}\r\n                  </p>\r\n                </div>\r\n\r\n                {/* Teams */}\r\n                <div className=\"flex gap-2 shrink-0\">\r\n                  {(s.teams ?? []).map((t: any) => (\r\n                    <div key={t.id} className=\"flex flex-col items-center gap-1\">\r\n                      <div className=\"w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold\"\r\n                        style={{ background: t.color, color: '#000' }}>\r\n                        {t.name.charAt(0)}\r\n                      </div>\r\n                      <span className=\"text-xs font-black\" style={{ color: 'var(--color-text-primary)' }}>{t.score}</span>\r\n                    </div>\r\n                  ))}\r\n                </div>\r\n\r\n                {/* Winner */}\r\n                {s.state === 'finished' && topTeam && (\r\n                  <div className=\"shrink-0 text-right min-w-[80px]\">\r\n                    <p className=\"text-[10px]\" style={{ color: 'var(--color-text-muted)' }}>в•ӘВәв”ҳГӨв”ҳГјв•ӘВәв•ӘВӘв•Әв–“</p>\r\n                    <p className=\"font-bold text-xs gradient-text-accent\">{topTeam.name}</p>\r\n                  </div>\r\n                )}\r\n\r\n                {/* Actions */}\r\n                {s.state !== 'finished' && (\r\n                  <button\r\n                    onClick={async () => {\r\n                      if (!confirm('в”ҳГ§в”ҳГӨ в•ӘГәв”ҳГҘв•ӘВ¬ в”ҳГ в•ӘВ¬в•ӘГәв”ҳГўв•ӘВ» в”ҳГ в”ҳГҘ в•Әв–’в•Әв•‘в•ӘВҝв•ӘВ¬в”ҳГў в”ҳГјв”ҳГЁ в•ӘГ‘в”ҳГҘв”ҳГ§в•ӘВәв•ӘГӯ в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘВәв”ҳГӨв•ӘВјв”ҳГӨв•Әв”Ӯв•ӘвҢҗ в”ҳГјв”ҳГӘв•Әв–’в•ӘВәв”ҳГҜв•ӘЖ’')) return\r\n                      const { error } = await supabase.from('sessions').update({ state: 'finished' }).eq('id', s.id)\r\n                      if (error) toast.error('в•ӘВ«в•Әв•–в•ӘГә: ' + error.message)\r\n                      else {\r\n                        toast.success('в•ӘВ¬в”ҳГ  в•ӘГ‘в”ҳГҘв”ҳГ§в•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв•ӘВјв”ҳГӨв•Әв”Ӯв•ӘвҢҗ в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ')\r\n                        // Reload data\r\n                        const { data } = await supabase.from('sessions').select(`*, teams(id,name,score,color), profiles(email)`).order('created_at', { ascending: false }).limit(50)\r\n                        setSessions(data ?? [])\r\n                      }\r\n                    }}\r\n                    className=\"shrink-0 p-2 rounded-xl bg-red-500/10 text-red-500 border border-red-500/20 hover:bg-red-500/20 transition-all text-[10px] font-bold\"\r\n                  >\r\n                    в•ӘГ‘в”ҳГҘв”ҳГ§в•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв•ӘВјв”ҳГӨв•Әв”Ӯв•ӘвҢҗ\r\n                  </button>\r\n                )}\r\n              </div>\r\n            )\r\n          })}\r\n          {sessions.length === 0 && (\r\n            <div className=\"py-16 text-center\" style={{ color: 'var(--color-text-muted)' }}>в”ҳГӨв•ӘВә в•ӘВ¬в”ҳГӘв•ӘВјв•ӘВ» в•ӘВјв”ҳГӨв•Әв”Ӯв•ӘВәв•ӘВ¬</div>\r\n          )}\r\n        </div>\r\n      )}\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\app\\admin\\system\\page.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'supabase'. Either include it or remove the dependency array.","line":25,"column":6,"nodeType":"ArrayExpression","endLine":25,"endColumn":8,"suggestions":[{"desc":"Update the dependencies array to be: [supabase]","fix":{"range":[694,696],"text":"[supabase]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useEffect, useState } from 'react'\nimport { createClient } from '@/lib/supabaseClient'\nimport toast from 'react-hot-toast'\nimport { motion } from 'framer-motion'\nimport {\n  SYSTEM_DEFAULTS,\n  type SystemSettings,\n  getAppSettings,\n  saveAppSettings,\n} from '@/lib/appSettings'\n\nexport default function AdminSystemPage() {\n  const supabase = createClient()\n  const [settings, setSettings] = useState<SystemSettings>(SYSTEM_DEFAULTS)\n  const [loading, setLoading] = useState(true)\n  const [saving, setSaving] = useState(false)\n\n  useEffect(() => {\n    getAppSettings('system', SYSTEM_DEFAULTS, supabase).then(s => {\n      setSettings(s)\n      setLoading(false)\n    })\n  }, [])\n\n  async function save() {\n    setSaving(true)\n    const { error } = await saveAppSettings('system', settings, supabase)\n    if (error) toast.error('в•ӘВ«в•Әв•–в•ӘГә: ' + error.message)\n    else toast.success('в•ӘВ¬в”ҳГ  в•ӘВЎв”ҳГјв•Әв•• в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГ©в”ҳГҘв”ҳГЁв•ӘвҢҗ в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ')\n    setSaving(false)\n  }\n\n  if (loading) return <div className=\"p-8 animate-pulse space-y-4\">\n    <div className=\"h-8 w-48 bg-white/10 rounded\" />\n    <div className=\"h-32 bg-white/5 rounded-2xl\" />\n  </div>\n\n  return (\n    <div className=\"p-8 max-w-3xl space-y-8\">\n      <div>\n        <h1 className=\"text-3xl font-black gradient-text-primary\">в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГ©в”ҳГҘв”ҳГЁв•ӘвҢҗ</h1>\n        <p style={{ color: 'var(--color-text-secondary)' }}>в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГўв”ҳГ  в”ҳГјв”ҳГЁ в•ӘВЎв•ӘВәв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ в•ӘГ® в”ҳГӘв•Әв•ўв•Әв•Ј в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГЁв•ӘВәв”ҳГҘв•ӘвҢҗв•ӘГ® в”ҳГӘв•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВ»в•ӘВ«в”ҳГӘв”ҳГӨ.</p>\n      </div>\n\n      <div className=\"space-y-6\">\n        {/* Maintenance Mode */}\n        <div className={`card-glass p-6 border-2 transition-all ${settings.is_maintenance ? 'border-red-500/30 bg-red-500/5' : 'border-transparent'}`}>\n          <div className=\"flex items-center justify-between mb-4\">\n            <div>\n              <h3 className=\"font-bold text-lg\" style={{ color: settings.is_maintenance ? '#ef4444' : 'var(--color-text-primary)' }}>\n                в”ҳГӘв•Әв•ўв•Әв•Ј в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГЁв•ӘВәв”ҳГҘв•ӘвҢҗ (Maintenance Mode)\n              </h3>\n              <p className=\"text-xs mt-1\" style={{ color: 'var(--color-text-muted)' }}>\n                в•Әв•Јв”ҳГҘв•ӘВ» в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГјв•Әв•Јв”ҳГЁв”ҳГӨв•ӘГ® в•Әв”Ӯв”ҳГЁв•ӘВ¬в”ҳГ  в•ӘВ¬в•ӘВЎв”ҳГӘв”ҳГЁв”ҳГӨ в•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳГҘ (в•Әв•‘в”ҳГЁв•Әв–’ в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘГұв”ҳГӘв”ҳГӨв”ҳГЁв”ҳГҘ) в•ӘГ‘в”ҳГӨв”ҳГ« в•Әв•Ўв”ҳГјв•ӘВЎв•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГЁв•ӘВәв”ҳГҘв•ӘвҢҗ.\n              </p>\n            </div>\n            <button\n              onClick={() => setSettings(s => ({ ...s, is_maintenance: !s.is_maintenance }))}\n              className={`relative w-14 h-7 rounded-full transition-all ${settings.is_maintenance ? 'bg-red-600' : 'bg-white/10'}`}\n            >\n              <div className={`absolute top-1 left-1 w-5 h-5 rounded-full bg-white transition-all ${settings.is_maintenance ? 'translate-x-7' : ''}`} />\n            </button>\n          </div>\n\n          {settings.is_maintenance && (\n            <motion.div initial={{ opacity: 0, height: 0 }} animate={{ opacity: 1, height: 'auto' }} className=\"space-y-4 pt-4 border-t border-red-500/20\">\n              <div>\n                <label className=\"label\">в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГЁв•ӘВәв”ҳГҘв•ӘвҢҗ (в•Әв•Јв•Әв–’в•ӘВҝв”ҳГЁ)</label>\n                <textarea\n                  className=\"input w-full min-h-[80px]\"\n                  value={settings.maintenance_msg_ar}\n                  onChange={e => setSettings(s => ({ ...s, maintenance_msg_ar: e.target.value }))}\n                />\n              </div>\n              <div>\n                <label className=\"label\">Maintenance Message (EN)</label>\n                <textarea\n                  className=\"input w-full min-h-[80px]\"\n                  value={settings.maintenance_msg_en}\n                  onChange={e => setSettings(s => ({ ...s, maintenance_msg_en: e.target.value }))}\n                />\n              </div>\n            </motion.div>\n          )}\n        </div>\n\n        {/* Security Settings */}\n        <div className=\"card-glass p-6 space-y-4\">\n          <h3 className=\"font-bold text-lg border-b border-white/10 pb-3\">в•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘГәв”ҳГ в•ӘВәв”ҳГҘ в”ҳГӘв•ӘВәв”ҳГӨв•ӘВ»в•ӘВ«в”ҳГӘв”ҳГӨ</h3>\n          <div className=\"flex items-center justify-between\">\n            <div>\n              <p className=\"font-bold text-sm\">в•ӘВәв”ҳГӨв•Әв”Ӯв”ҳГ в•ӘВәв•ӘВЎ в•ӘВҝв•ӘВ¬в•Әв”Ӯв•ӘВјв”ҳГЁв”ҳГӨ в”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ в”ҳГЁв”ҳГҘ в•ӘВјв•ӘВ»в•ӘВ»</p>\n              <p className=\"text-xs text-white/40\">в•ӘВ¬в•Әв•Јв•Әв•–в”ҳГЁв”ҳГӨ в”ҳГ§в•Әв–‘в•ӘВә в•ӘВәв”ҳГӨв•ӘВ«в”ҳГЁв•ӘВәв•Әв–’ в•Әв”Ӯв”ҳГЁв”ҳГ в”ҳГҘв•Әв•Ј в•ӘГ‘в”ҳГҘв•Әв”Өв•ӘВәв•ӘГӯ в•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝв•ӘВәв•ӘВ¬ в•ӘВјв•ӘВ»в”ҳГЁв•ӘВ»в•ӘвҢҗ в•ӘВЎв•ӘВәв”ҳГӨв”ҳГЁв•ӘВәв”ҳГҜ.</p>\n            </div>\n            <button\n              onClick={() => setSettings(s => ({ ...s, allow_new_logins: !s.allow_new_logins }))}\n              className={`relative w-12 h-6 rounded-full transition-all ${settings.allow_new_logins ? 'bg-green-600' : 'bg-white/10'}`}\n            >\n              <div className={`absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-white transition-all ${settings.allow_new_logins ? 'translate-x-6' : ''}`} />\n            </button>\n          </div>\n        </div>\n\n        {/* Danger Zone */}\n        <div className=\"card-glass p-6 border border-red-500/20 space-y-4\">\n          <h3 className=\"font-bold text-lg text-red-400\">в”ҳГ в”ҳГҘв•Әв•–в”ҳГ©в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ«в•Әв•–в•Әв–’</h3>\n          <p className=\"text-xs text-white/40\">в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв•Әв–’в•ӘВәв•ӘГӯв•ӘВәв•ӘВ¬ в”ҳГ©в•ӘВ» в•ӘВ¬в•ӘГұв•ӘВ»в”ҳГЁ в•ӘГ‘в”ҳГӨв”ҳГ« в”ҳГ в•Әв”Ӯв•ӘВЎ в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘГәв”ҳГӘ в•ӘВ¬в•Әв•Јв•Әв•–в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ .</p>\n          <button\n            onClick={() => toast.error('в”ҳГ§в•Әв–‘в•ӘВә в•ӘВәв”ҳГӨв•ӘВ«в”ҳГЁв•ӘВәв•Әв–’ в”ҳГЁв•ӘВ¬в•Әв•–в”ҳГӨв•ӘВҝ в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв”ҳГЁв•ӘВәв•ӘВ¬ Super Admin')}\n            className=\"px-4 py-2 rounded-xl bg-red-500/10 text-red-500 border border-red-500/30 text-xs font-bold hover:bg-red-500/20 transition-all\"\n          >\n            в•ӘВ¬в”ҳГ§в”ҳГЁв•ӘВӘв•ӘвҢҗ в”ҳГ©в•ӘВәв•Әв•Јв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ (Reset DB)\n          </button>\n        </div>\n      </div>\n\n      <button\n        onClick={save}\n        disabled={saving}\n        className=\"btn btn-primary btn-lg w-full\"\n      >\n        {saving ? 'в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•ӘВЎв”ҳГјв•Әв••...' : 'в•ӘВЎв”ҳГјв•Әв•• в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГ©в”ҳГҘв”ҳГЁв•ӘвҢҗ'}\n      </button>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\app\\admin\\themes\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'AnimatePresence' is defined but never used.","line":13,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":13,"endColumn":33,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"AnimatePresence"},"fix":{"range":[530,547],"text":""},"desc":"Remove unused variable \"AnimatePresence\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ app/admin/themes/page.tsx О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n// Admin control panel to preview, apply, and generate special links for all themes.\n//\n// О“ГңГЎвҲ©в••Г…  Add your own admin auth guard at the top of this component (check session\n//     role === 'admin' from Supabase, redirect otherwise).\n//\n// Usage:\n//   Navigate to /admin/themes in your browser.\n//   The panel lives outside the user-facing dashboard so admins can test freely.\n\nimport { useState, useCallback } from 'react'\nimport { motion, AnimatePresence } from 'framer-motion'\nimport { useTheme } from '@/context/ThemeContext'\nimport { themes, themesList } from '@/lib/themes'\nimport { Theme, ThemeId } from '@/types/theme'\n\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ Helpers О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nfunction buildLink(baseUrl: string, themeId: ThemeId, path = '/dashboard') {\n  return `${baseUrl}${path}?theme=${themeId}`\n}\n\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ Sub-components О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nfunction ColorSwatch({ color }: { color: string }) {\n  return (\n    <div\n      className=\"w-5 h-5 rounded-full border border-white/10 flex-shrink-0\"\n      style={{ backgroundColor: color }}\n      title={color}\n    />\n  )\n}\n\nfunction CopyButton({\n  label,\n  value,\n  copyId,\n  activeCopyId,\n  onCopy,\n}: {\n  label: string\n  value: string\n  copyId: string\n  activeCopyId: string | null\n  onCopy: (id: string, value: string) => void\n}) {\n  const copied = activeCopyId === copyId\n  return (\n    <button\n      onClick={() => onCopy(copyId, value)}\n      className=\"flex-1 py-1.5 rounded-xl text-xs font-medium transition-all border\"\n      style={{\n        borderColor: copied ? '#22c55e44' : '#ffffff11',\n        color: copied ? '#22c55e' : '#9CA3AF',\n        backgroundColor: copied ? '#22c55e11' : '#ffffff07',\n      }}\n    >\n      {copied ? 'О“ВЈГҙ Copied' : label}\n    </button>\n  )\n}\n\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ Theme Card О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nfunction ThemeCard({\n  t,\n  isActive,\n  previewName,\n  activeCopyId,\n  onApply,\n  onCopy,\n}: {\n  t: Theme\n  isActive: boolean\n  previewName: string\n  activeCopyId: string | null\n  onApply: (id: ThemeId) => void\n  onCopy: (id: string, value: string) => void\n}) {\n  const origin = typeof window !== 'undefined' ? window.location.origin : 'https://yourapp.com'\n\n  return (\n    <motion.div\n      layout\n      initial={{ opacity: 0, y: 16 }}\n      animate={{ opacity: 1, y: 0 }}\n      className=\"relative rounded-2xl border overflow-hidden transition-shadow duration-300\"\n      style={{\n        backgroundColor: isActive ? `${t.colors.primary}12` : t.colors.surface,\n        borderColor: isActive ? t.colors.primary : t.colors.border,\n        boxShadow: isActive ? t.colors.glow : 'none',\n      }}\n    >\n      {/* Active badge */}\n      {isActive && (\n        <div\n          className=\"absolute top-3 end-3 text-[10px] font-bold px-2 py-0.5 rounded-full\"\n          style={{ backgroundColor: t.colors.primary, color: '#fff' }}\n        >\n          ACTIVE\n        </div>\n      )}\n\n      <div className=\"p-5 flex flex-col gap-4\">\n        {/* Header */}\n        <div className=\"flex items-center gap-3\">\n          <div\n            className=\"w-11 h-11 rounded-xl flex items-center justify-center text-2xl flex-shrink-0\"\n            style={{ backgroundColor: `${t.colors.primary}22` }}\n          >\n            {t.emoji}\n          </div>\n          <div>\n            <p className=\"text-sm font-semibold text-white leading-tight\">{t.name}</p>\n            <p className=\"text-xs mt-0.5\" style={{ color: t.colors.primary }}>\n              {t.nameAr}\n            </p>\n          </div>\n        </div>\n\n        {/* Colour palette */}\n        <div className=\"flex items-center gap-2\">\n          {[t.colors.primary, t.colors.primaryLight, t.colors.secondary, t.colors.accent,\n            t.colors.surface, t.colors.border].map((c, i) => (\n            <ColorSwatch key={i} color={c} />\n          ))}\n        </div>\n\n        {/* Greeting preview */}\n        <div\n          className=\"rounded-xl p-3\"\n          style={{\n            backgroundColor: `${t.colors.primary}0D`,\n            borderLeft: `3px solid ${t.colors.primary}`,\n          }}\n        >\n          <p className=\"text-[10px] uppercase tracking-wider mb-1.5\" style={{ color: t.colors.textMuted }}>\n            Greeting preview\n          </p>\n          <p className=\"text-sm font-semibold\" style={{ color: t.colors.text }}>\n            {t.greeting(previewName || null)}\n          </p>\n          <p className=\"text-xs mt-1 opacity-80\" style={{ color: t.colors.primary }}>\n            {t.greetingAr(previewName || null)}\n          </p>\n          {t.subGreeting && (\n            <p className=\"text-[11px] mt-1.5\" style={{ color: t.colors.textMuted }}>\n              {t.subGreeting}\n            </p>\n          )}\n        </div>\n\n        {/* Actions */}\n        <div className=\"flex flex-col gap-2\">\n          {/* Apply button */}\n          <button\n            onClick={() => onApply(t.id)}\n            disabled={isActive}\n            className=\"w-full py-2 rounded-xl text-sm font-bold transition-all active:scale-[0.97] disabled:cursor-default\"\n            style={{\n              background: isActive\n                ? `${t.colors.primary}22`\n                : `linear-gradient(135deg, ${t.colors.primary}, ${t.colors.accent})`,\n              color: isActive ? t.colors.primary : '#fff',\n              boxShadow: isActive ? 'none' : `0 4px 16px ${t.colors.primary}44`,\n            }}\n          >\n            {isActive ? 'О“ВЈГҙ Currently Active' : 'Apply Theme'}\n          </button>\n\n          {/* Copy link buttons */}\n          <div className=\"flex gap-2\">\n            <CopyButton\n              label=\"вүЎЖ’Г…ГЎ Home Link\"\n              copyId={`home-${t.id}`}\n              value={buildLink(origin, t.id, '/')}\n              activeCopyId={activeCopyId}\n              onCopy={onCopy}\n            />\n            <CopyButton\n              label=\"вүЎЖ’ГҙГҜ Dashboard Link\"\n              copyId={`dash-${t.id}`}\n              value={buildLink(origin, t.id, '/dashboard')}\n              activeCopyId={activeCopyId}\n              onCopy={onCopy}\n            />\n          </div>\n\n          {/* Raw URL display */}\n          <p\n            className=\"text-[10px] px-3 py-1.5 rounded-lg font-mono truncate\"\n            style={{ backgroundColor: `${t.colors.border}50`, color: t.colors.textMuted }}\n          >\n            ?theme={t.id}\n          </p>\n        </div>\n      </div>\n    </motion.div>\n  )\n}\n\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ Page О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nexport default function AdminThemesPage() {\n  const { themeId, theme, setTheme } = useTheme()\n  const [previewName, setPreviewName] = useState('Ahmed')\n  const [activeCopyId, setActiveCopyId] = useState<string | null>(null)\n  const [resetConfirm, setResetConfirm] = useState(false)\n\n  const handleCopy = useCallback((id: string, value: string) => {\n    navigator.clipboard.writeText(value).catch(() => {})\n    setActiveCopyId(id)\n    setTimeout(() => setActiveCopyId(null), 2200)\n  }, [])\n\n  const handleReset = () => {\n    if (!resetConfirm) { setResetConfirm(true); setTimeout(() => setResetConfirm(false), 3000); return }\n    setTheme('default')\n    setResetConfirm(false)\n  }\n\n  return (\n    <div\n      className=\"min-h-screen p-6 md:p-10 transition-colors duration-500\"\n      style={{ backgroundColor: theme.colors.background }}\n    >\n      <div className=\"max-w-5xl mx-auto\">\n\n        {/* О“Г¶ГҮО“Г¶ГҮ Header О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n        <div className=\"mb-8\">\n          <div className=\"flex flex-wrap items-start justify-between gap-4\">\n            <div>\n              <div className=\"flex items-center gap-2.5 mb-1\">\n                <span className=\"text-2xl\">вүЎЖ’Г„Вҝ</span>\n                <h1 className=\"text-xl md:text-2xl font-bold text-white\">Theme Control Center</h1>\n              </div>\n              <p className=\"text-sm\" style={{ color: theme.colors.textMuted }}>\n                Apply themes, generate special links, and preview greetings.\n              </p>\n            </div>\n\n            {/* Reset button */}\n            <button\n              onClick={handleReset}\n              className=\"text-xs px-4 py-2 rounded-xl border transition-colors\"\n              style={{\n                borderColor: resetConfirm ? '#ef444466' : theme.colors.border,\n                color: resetConfirm ? '#ef4444' : theme.colors.textMuted,\n                backgroundColor: resetConfirm ? '#ef444411' : 'transparent',\n              }}\n            >\n              {resetConfirm ? 'О“ГңГЎ Click again to reset' : 'О“ГҘв•‘ Reset to Default'}\n            </button>\n          </div>\n\n          {/* Active theme pill */}\n          <div\n            className=\"mt-4 inline-flex items-center gap-2 px-4 py-2 rounded-xl border\"\n            style={{\n              borderColor: theme.colors.borderGlow,\n              backgroundColor: `${theme.colors.primary}14`,\n            }}\n          >\n            <span className=\"text-base\">{themes[themeId].emoji}</span>\n            <span className=\"text-sm font-semibold\" style={{ color: theme.colors.primary }}>\n              Active theme: {themes[themeId].name}\n            </span>\n          </div>\n        </div>\n\n        {/* О“Г¶ГҮО“Г¶ГҮ Preview name input О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n        <div\n          className=\"mb-8 p-5 rounded-2xl border\"\n          style={{ backgroundColor: theme.colors.surface, borderColor: theme.colors.border }}\n        >\n          <label className=\"block text-xs font-semibold uppercase tracking-wider mb-3\"\n                 style={{ color: theme.colors.textMuted }}>\n            Preview greeting with a name\n          </label>\n          <div className=\"flex gap-3 items-center\">\n            <span className=\"text-2xl\">вүЎЖ’ГҰГұ</span>\n            <input\n              type=\"text\"\n              value={previewName}\n              onChange={(e) => setPreviewName(e.target.value)}\n              placeholder=\"Enter any nameО“ГҮВӘ\"\n              className=\"flex-1 bg-transparent border rounded-xl px-4 py-2.5 text-sm text-white\n                         outline-none transition-colors placeholder:text-gray-600\"\n              style={{ borderColor: theme.colors.border }}\n              onFocus={(e) => (e.target.style.borderColor = theme.colors.primary)}\n              onBlur={(e) => (e.target.style.borderColor = theme.colors.border)}\n            />\n          </div>\n        </div>\n\n        {/* О“Г¶ГҮО“Г¶ГҮ Theme cards grid О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10\">\n          {themesList.map((t) => (\n            <ThemeCard\n              key={t.id}\n              t={t}\n              isActive={t.id === themeId}\n              previewName={previewName}\n              activeCopyId={activeCopyId}\n              onApply={setTheme}\n              onCopy={handleCopy}\n            />\n          ))}\n        </div>\n\n        {/* О“Г¶ГҮО“Г¶ГҮ How it works guide О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n        <div\n          className=\"p-6 rounded-2xl border\"\n          style={{ backgroundColor: theme.colors.surface, borderColor: theme.colors.border }}\n        >\n          <h2 className=\"text-base font-bold text-white mb-5\">вүЎЖ’ГҙГ» How Special Links Work</h2>\n          <div className=\"grid md:grid-cols-4 gap-4\">\n            {([\n              { step: '1', title: 'Copy the link', desc: 'Use \"Home Link\" or \"Dashboard Link\" on any theme card.' },\n              { step: '2', title: 'Share with a group', desc: 'Send to your medical team, engineering dept, teachers, etc.' },\n              { step: '3', title: 'Auto-preview', desc: 'The theme applies instantly when they open the link.' },\n              { ste