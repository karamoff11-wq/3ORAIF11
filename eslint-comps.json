n && (\r\n                  <div className=\"absolute inset-0 z-10 flex items-center justify-center rounded-3xl bg-black/40 backdrop-blur-sm\">\r\n                    <span className=\"bg-purple-500/20 text-purple-300 border border-purple-500/30 px-4 py-2 rounded-full text-sm font-bold\">в”ҳГ©в•Әв–’в”ҳГЁв•ӘВҝв•ӘВәв”ҳГҜ О“ВЈВҝ</span>\r\n                  </div>\r\n                )}\r\n                <div className=\"flex items-center justify-between\">\r\n                  <h3 className=\"font-black text-lg\" style={{ color: l.color }}>{l.icon} {l.title}</h3>\r\n                  <span className=\"text-xs text-white/30\">{catPhrases.length} в•ӘВјв”ҳГ в”ҳГӨв•ӘвҢҗ</span>\r\n                </div>\r\n\r\n                {/* Phrase list */}\r\n                <div className=\"space-y-2 max-h-64 overflow-y-auto\">\r\n                  {catPhrases.length === 0 && <p className=\"text-white/20 text-xs text-center py-4\">в”ҳГӨв•ӘВә в•ӘВ¬в”ҳГӘв•ӘВјв•ӘВ» в•ӘВјв”ҳГ в”ҳГӨ в•ӘВҝв•Әв•Јв•ӘВ»</p>}\r\n                  {catPhrases.map(p => (\r\n                    <div key={p.id} className={`flex items-center gap-2 p-3 rounded-xl ${l.bg} group`}>\r\n                      <p className=\"flex-1 text-sm text-white/80 leading-snug\">{p.text}</p>\r\n                      <button\r\n                        onClick={() => deleteAnswerPhrase(p.id)}\r\n                        className=\"flex-shrink-0 w-6 h-6 rounded-full text-white/20 hover:text-red-400 hover:bg-red-500/10 flex items-center justify-center text-xs transition-colors opacity-0 group-hover:opacity-100\"\r\n                      >О“ВЈГІ</button>\r\n                    </div>\r\n                  ))}\r\n                </div>\r\n\r\n                {/* Add phrase inline */}\r\n                {addingAnswerCategory === cat ? (\r\n                  <div className=\"space-y-2\">\r\n                    <textarea\r\n                      autoFocus\r\n                      value={newAnswerPhrase.text}\r\n                      onChange={e => setNewAnswerPhrase({ text: e.target.value, category: cat })}\r\n                      placeholder=\"в•ӘВәв”ҳГўв•ӘВ¬в•ӘВҝ в•ӘВәв”ҳГӨв•ӘВјв”ҳГ в”ҳГӨв•ӘвҢҗ...\"\r\n                      className=\"input w-full min-h-[60px] text-sm\"\r\n                    />\r\n                    <div className=\"flex gap-2\">\r\n                      <button onClick={() => addAnswerPhrase(cat)} className=\"btn btn-primary flex-1 text-sm py-2\">в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ</button>\r\n                      <button onClick={() => setAddingAnswerCategory(null)} className=\"btn btn-ghost text-sm py-2\">в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ</button>\r\n                    </div>\r\n                  </div>\r\n                ) : (\r\n                  <button\r\n                    onClick={() => { setAddingAnswerCategory(cat); setNewAnswerPhrase({ text: '', category: cat }) }}\r\n                    className={`w-full py-2 rounded-xl border border-dashed text-sm font-bold transition-colors ${l.border} text-white/40 hover:text-white/70`}\r\n                  >+ в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ в•ӘВјв”ҳГ в”ҳГӨв•ӘвҢҗ</button>\r\n                )}\r\n              </div>\r\n            )\r\n          })}\r\n        </div>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\app\\admin\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":46,"column":40,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":46,"endColumn":43,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1598,1601],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1598,1601],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'i' is defined but never used.","line":179,"column":57,"nodeType":"Identifier","messageId":"unusedVar","endLine":179,"endColumn":58}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useState, useMemo } from 'react'\r\nimport { createClient } from '@/lib/supabaseClient'\r\nimport { motion } from 'framer-motion'\r\n\r\ninterface Stats {\r\n  totalSessions: number\r\n  activeSessions: number\r\n  totalQuestions: number\r\n  totalCategories: number\r\n  recentSessions: {\r\n    id: string\r\n    state: string\r\n    created_at: string\r\n    teams: {\r\n      name: string\r\n      score: number\r\n    }[]\r\n  }[]\r\n  popularCategories: { name: string; count: number; color: string }[]\r\n  playtimeDistribution: number[]\r\n}\r\n\r\nexport default function AdminHomePage() {\r\n  const supabase = useMemo(() => createClient(), [])\r\n  const [stats, setStats] = useState<Stats | null>(null)\r\n\r\n  useEffect(() => {\r\n    async function load() {\r\n      // Fetch stats\r\n      const [sessions, questions, categories, recent] = await Promise.all([\r\n        supabase.from('sessions').select('id, state', { count: 'exact' }),\r\n        supabase.from('questions').select('id', { count: 'exact' }),\r\n        supabase.from('categories').select('id', { count: 'exact' }),\r\n        supabase.from('sessions').select('*, teams(name,score)').order('created_at', { ascending: false }).limit(8),\r\n      ])\r\n\r\n      // Fetch popular categories (Join sessions and categories)\r\n      const { data: popularData } = await supabase\r\n        .from('session_categories')\r\n        .select('category_id, categories(name, topics(color))')\r\n      \r\n      const counts: Record<string, { name: string, count: number, color: string }> = {}\r\n      popularData?.forEach((item) => {\r\n        const cat = item.categories as any\r\n        if (!cat) return\r\n        if (!counts[cat.name]) {\r\n          counts[cat.name] = { name: cat.name, count: 0, color: cat.topics?.color || '#8b5cf6' }\r\n        }\r\n        counts[cat.name].count++\r\n      })\r\n\r\n      const sortedPopular = Object.values(counts)\r\n        .sort((a, b) => b.count - a.count)\r\n        .slice(0, 4)\r\n\r\n      // Playtime Distribution (Sessions per day for last 7 days)\r\n      const last7Days = Array(7).fill(0).map((_, i) => {\r\n        const d = new Date()\r\n        d.setDate(d.getDate() - i)\r\n        return d.toISOString().split('T')[0]\r\n      }).reverse()\r\n\r\n      const { data: sessionHistory } = await supabase\r\n        .from('sessions')\r\n        .select('created_at')\r\n        .gte('created_at', last7Days[0])\r\n\r\n      const distribution = last7Days.map(date => {\r\n        return sessionHistory?.filter((s) => s.created_at.startsWith(date)).length || 0\r\n      })\r\n\r\n      setStats({\r\n        totalSessions: sessions.count ?? 0,\r\n        activeSessions: (sessions.data ?? []).filter((s) => s.state === 'playing').length,\r\n        totalQuestions: questions.count ?? 0,\r\n        totalCategories: categories.count ?? 0,\r\n        recentSessions: recent.data ?? [],\r\n        popularCategories: sortedPopular,\r\n        playtimeDistribution: distribution\r\n      })\r\n    }\r\n    load()\r\n  }, [supabase])\r\n\r\n  const cards = stats ? [\r\n    { label: 'в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв•ӘВјв”ҳГӨв•Әв”Ӯв•ӘВәв•ӘВ¬',   value: stats.totalSessions,   icon: 'вүЎЖ’Г„В«', color: 'var(--color-primary)' },\r\n    { label: 'в•ӘВјв”ҳГӨв•Әв”Ӯв•ӘВәв•ӘВ¬ в”ҳГҘв•Әв”Өв•Әв•–в•ӘвҢҗ',       value: stats.activeSessions,  icon: 'О“ГңГӯ', color: '#10b981' },\r\n    { label: 'в•ӘГ‘в•ӘВјв”ҳГ в•ӘВәв”ҳГӨв”ҳГЁ в•ӘВәв”ҳГӨв•ӘГәв•Әв”Ӯв•ӘВӘв”ҳГӨв•ӘвҢҗ',   value: stats.totalQuestions,  icon: 'О“ВҘГҙ', color: 'var(--color-accent)' },\r\n    { label: 'в•ӘВәв”ҳГӨв”ҳГјв•ӘВӘв•ӘВәв•ӘВ¬',            value: stats.totalCategories, icon: 'вүЎЖ’ГҙГң', color: '#a855f7' },\r\n  ] : []\r\n\r\n  return (\r\n    <div className=\"p-8\">\r\n      <div className=\"mb-8\">\r\n        <h1 className=\"text-3xl font-black gradient-text-primary\">в”ҳГӨв”ҳГӘв•ӘВЎв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в•ӘвҢҗ</h1>\r\n        <p style={{ color: 'var(--color-text-secondary)' }}>в”ҳГҘв•Әв••в•Әв–’в•ӘвҢҗ в•Әв•Јв•ӘВәв”ҳГ в•ӘвҢҗ в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВәв”ҳГӨв”ҳГ в”ҳГҘв•Әв•Ўв•ӘвҢҗ</p>\r\n      </div>\r\n\r\n      {/* Stats */}\r\n      <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10\">\r\n        {!stats ? (\r\n          Array(4).fill(0).map((_, i) => (\r\n            <div key={i} className=\"card-glass h-32 animate-shimmer\" />\r\n          ))\r\n        ) : cards.map(({ label, value, icon, color }, i) => (\r\n          <motion.div\r\n            key={label}\r\n            initial={{ opacity: 0, y: 20 }}\r\n            animate={{ opacity: 1, y: 0 }}\r\n            transition={{ delay: i * 0.08 }}\r\n            className=\"card-glass flex flex-col gap-3\"\r\n          >\r\n            <div className=\"flex items-center justify-between\">\r\n              <span className=\"text-2xl\">{icon}</span>\r\n              <span className=\"text-3xl font-black\" style={{ color }}>{value}</span>\r\n            </div>\r\n            <p className=\"text-sm font-semibold\" style={{ color: 'var(--color-text-secondary)' }}>{label}</p>\r\n          </motion.div>\r\n        ))}\r\n      </div>\r\n\r\n      {/* Recent Sessions & Analytics */}\r\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-8\">\r\n        \r\n        {/* Sessions Table */}\r\n        <div className=\"lg:col-span-2\">\r\n          <h2 className=\"text-xl font-bold mb-4\" style={{ color: 'var(--color-text-primary)' }}>в•ӘГів•ӘВ«в•Әв–’ в•ӘВәв”ҳГӨв•ӘВјв”ҳГӨв•Әв”Ӯв•ӘВәв•ӘВ¬</h2>\r\n          <div className=\"card rounded-2xl overflow-hidden\" style={{ padding: 0 }}>\r\n            <table className=\"w-full text-sm\">\r\n              <thead>\r\n                <tr style={{ background: 'var(--color-surface-2)', borderBottom: '1px solid var(--color-border)' }}>\r\n                  {['в•ӘВәв”ҳГӨв”ҳГ в•Әв•Јв•Әв–’в”ҳГҰв”ҳГј', 'в•ӘВәв”ҳГӨв•ӘВЎв•ӘВәв”ҳГӨв•ӘвҢҗ', 'в•ӘВәв”ҳГӨв”ҳГјв•Әв–’в”ҳГ©', 'в”ҳГӘв”ҳГ©в•ӘВ¬ в•ӘВәв”ҳГӨв•ӘГ‘в”ҳГҘв•Әв”Өв•ӘВәв•ӘГӯ'].map(h => (\r\n                    <th key={h} className=\"px-4 py-3 text-right font-bold\" style={{ color: 'var(--color-text-secondary)' }}>{h}</th>\r\n                  ))}\r\n                </tr>\r\n              </thead>\r\n              <tbody>\r\n                {(stats?.recentSessions ?? []).map((s, i) => (\r\n                  <tr\r\n                    key={s.id}\r\n                    style={{\r\n                      borderBottom: '1px solid var(--color-border)',\r\n                      background: i % 2 === 0 ? 'transparent' : 'rgba(255,255,255,0.01)'\r\n                    }}\r\n                  >\r\n                    <td className=\"px-4 py-3 font-mono text-xs\" style={{ color: 'var(--color-text-muted)' }}>\r\n                      {s.id.slice(0,8)}...\r\n                    </td>\r\n                    <td className=\"px-4 py-3\">\r\n                      <span className=\"px-2 py-1 rounded-full text-[10px] font-bold\" style={{\r\n                        background: s.state === 'playing' ? 'rgba(16,185,129,0.1)' : s.state === 'finished' ? 'rgba(239,68,68,0.1)' : 'rgba(255,255,255,0.05)',\r\n                        color: s.state === 'playing' ? '#10b981' : s.state === 'finished' ? '#ef4444' : 'var(--color-text-muted)'\r\n                      }}>\r\n                        {s.state === 'playing' ? 'О“ГңГӯ в”ҳГЁв”ҳГӨв•Әв•Јв•ӘВҝ' : s.state === 'finished' ? 'О“ВЈГҙ в”ҳГ в”ҳГҘв•ӘВ¬в”ҳГ§в”ҳГЁ' : 'О“Г…в”Ӯ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’'}\r\n                      </span>\r\n                    </td>\r\n                    <td className=\"px-4 py-3\" style={{ color: 'var(--color-text-primary)' }}>\r\n                      {(s.teams ?? []).length} в”ҳГјв•Әв–’в”ҳГ©\r\n                    </td>\r\n                    <td className=\"px-4 py-3 text-[10px]\" style={{ color: 'var(--color-text-muted)' }}>\r\n                      {new Date(s.created_at).toLocaleDateString('ar-SA')}\r\n                    </td>\r\n                  </tr>\r\n                ))}\r\n              </tbody>\r\n            </table>\r\n          </div>\r\n        </div>\r\n\r\n        {/* Analytics / Top Categories */}\r\n        <div className=\"space-y-6\">\r\n          <h2 className=\"text-xl font-bold mb-4\" style={{ color: 'var(--color-text-primary)' }}>в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВЎв•Әв•Ўв•ӘВәв•ӘВӘв”ҳГЁв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в”ҳГ©в•ӘВ»в”ҳГ в•ӘвҢҗ</h2>\r\n          \r\n          <div className=\"card-glass p-6 space-y-4\">\r\n            <h3 className=\"text-sm font-bold opacity-50 uppercase tracking-widest\">в•ӘВәв”ҳГӨв”ҳГјв•ӘВӘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘГәв”ҳГўв•ӘВҪв•Әв–’ в•Әв”Өв•Әв•Јв•ӘВҝв”ҳГЁв•ӘвҢҗ</h3>\r\n            <div className=\"space-y-3\">\r\n              {(stats?.popularCategories ?? []).map((c, i) => {\r\n                const max = stats?.popularCategories[0]?.count || 1\r\n                return (\r\n                  <div key={c.name} className=\"space-y-1\">\r\n                    <div className=\"flex justify-between text-xs font-bold\">\r\n                      <span>{c.name}</span>\r\n                      <span style={{ color: c.color }}>{c.count} в”ҳГ в•Әв–’в•ӘвҢҗ</span>\r\n                    </div>\r\n                    <div className=\"h-1.5 w-full bg-white/5 rounded-full overflow-hidden\">\r\n                      <motion.div \r\n                        initial={{ width: 0 }} \r\n                        animate={{ width: `${(c.count/max)*100}%` }} \r\n                        className=\"h-full\" \r\n                        style={{ background: c.color }} \r\n                      />\r\n                    </div>\r\n                  </div>\r\n                )\r\n              })}\r\n              {stats?.popularCategories.length === 0 && (\r\n                <p className=\"text-xs text-white/20 text-center py-4 italic\">в”ҳГӨв•ӘВә в•ӘВ¬в”ҳГӘв•ӘВјв•ӘВ» в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в”ҳГўв•ӘВәв”ҳГјв”ҳГЁв•ӘвҢҗ</p>\r\n              )}\r\n            </div>\r\n          </div>\r\n\r\n          <div className=\"card-glass p-6\">\r\n            <div className=\"flex items-end justify-between h-24 gap-1\">\r\n              {(stats?.playtimeDistribution ?? [0,0,0,0,0,0,0]).map((count, i) => {\r\n                const max = Math.max(...(stats?.playtimeDistribution || [1])) || 1\r\n                const height = (count / max) * 100\r\n                return (\r\n                  <motion.div \r\n                    key={i}\r\n                    initial={{ height: 0 }}\r\n                    animate={{ height: `${height}%` }}\r\n                    className=\"flex-1 rounded-t-sm\"\r\n                    style={{ background: 'linear-gradient(to top, var(--color-primary), var(--color-primary-light))', opacity: 0.3 + (height/100)*0.7 }}\r\n                  />\r\n                )\r\n              })}\r\n            </div>\r\n            <div className=\"flex justify-between mt-2 text-[10px] opacity-40 font-bold\">\r\n              <span>в”ҳГ©в•ӘВҝв”ҳГӨ в”ҳВӘ в•ӘГәв”ҳГЁв•ӘВәв”ҳГ </span>\r\n              <span>в•ӘВәв”ҳГӨв”ҳГЁв”ҳГӘв”ҳГ </span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n      </div>\r\n\r\n      {/* Theme Control Quick Access */}\r\n      <div className=\"mt-12 mb-8\">\r\n        <h2 className=\"text-xl font-bold mb-4\" style={{ color: 'var(--color-text-primary)' }}>в•ӘВ¬в•ӘВјв•Әв–’в•ӘВҝв•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  в”ҳГӘв•ӘВәв”ҳГӨв”ҳГҘв”ҳГ в”ҳГӘ</h2>\r\n        <motion.div\r\n          whileHover={{ scale: 1.005 }}\r\n          className=\"card-glass relative overflow-hidden group cursor-pointer border\"\r\n          onClick={() => window.location.href = '/admin/themes'}\r\n          style={{ borderColor: 'rgba(168,85,247,0.3)', background: 'linear-gradient(135deg, rgba(168,85,247,0.05), rgba(99,102,241,0.05))' }}\r\n        >\r\n          {/* Decorative Background Glow */}\r\n          <div className=\"absolute top-0 right-0 w-64 h-64 bg-purple-500/10 blur-[80px] -mr-32 -mt-32\" />\r\n          \r\n          <div className=\"flex flex-wrap items-center gap-6 relative z-10 p-6\">\r\n            <div className=\"w-16 h-16 rounded-2xl flex items-center justify-center text-3xl bg-purple-500/20 text-purple-400 group-hover:scale-110 transition-transform\">\r\n              вүЎЖ’Г„Вҝ\r\n            </div>\r\n            <div className=\"flex-1 min-w-[200px]\">\r\n              <h3 className=\"text-lg font-bold text-white mb-1\">в”ҳГ в•Әв–’в”ҳГўв•Әв–“ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГўв”ҳГ  в•ӘВҝв•ӘВәв”ҳГӨв•ӘВҪв”ҳГЁв”ҳГ в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВ«в•ӘВәв•Әв•Ўв•ӘвҢҗ (Growth Engine)</h3>\r\n              <p className=\"text-sm opacity-60\">в”ҳГ©в”ҳГ  в•ӘВҝв•ӘВ¬в”ҳГӘв”ҳГӨв”ҳГЁв•ӘВ» в•Әв–’в”ҳГӘв•ӘВәв•ӘВҝв•Әв•– в•ӘВ«в•ӘВәв•Әв•Ўв•ӘвҢҗ в”ҳГӨв”ҳГӨв•ӘГәв•Әв•–в•ӘВҝв•ӘВәв•ӘГӯв•ӘГ® в•ӘВәв”ҳГӨв”ҳГ в”ҳГ§в”ҳГҘв•ӘВ»в•Әв”Ӯв”ҳГЁв”ҳГҘв•ӘГ® в•ӘГәв”ҳГӘ в”ҳГӨв•ӘГәв•Әв•Јв”ҳГЁв•ӘВәв•ӘВ» в•ӘВәв”ҳГӨв”ҳГ в”ҳГЁв”ҳГӨв•ӘВәв•ӘВ». в•ӘВҪв”ҳГЁв”ҳГ в•ӘВәв•ӘВ¬ в”ҳГ в•ӘВ¬в”ҳГўв•ӘВәв”ҳГ в”ҳГӨв•ӘвҢҗ в•ӘВ¬в”ҳГјв•Әв•Јв”ҳГҰв”ҳГӨ в•ӘВ¬в”ҳГӨв”ҳГ©в•ӘВәв•ӘВӘв”ҳГЁв•ӘВәв”ҳГҜ в•Әв•Јв”ҳГҘв•ӘВ» в•ӘВәв”ҳГӨв•Әв–“в”ҳГЁв•ӘВәв•Әв–’в•ӘвҢҗ.</p>\r\n            </div>\r\n            <div className=\"flex items-center gap-3\">\r\n              <span className=\"text-xs font-bold uppercase tracking-widest text-purple-400 opacity-60\">в•ӘВ¬в”ҳГјв•Әв•Јв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘГів”ҳГҘ</span>\r\n              <div className=\"w-10 h-10 rounded-full border border-purple-500/30 flex items-center justify-center text-purple-400 group-hover:bg-purple-500/20 transition-all\">\r\n                О“ГҘГҶ\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </motion.div>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\app\\admin\\questions\\page.tsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\app\\admin\\questions\\page.tsx:34:21\n  32 |     setLoading(false)\n  33 |   }\n> 34 |   useEffect(() => { load() }, [])\n     |                     ^^^^ Avoid calling setState() directly within an effect\n  35 |\n  36 |   function openAdd() {\n  37 |     setForm({ category_id: '', difficulty: 'easy', question: '', answer: '', media_url: '' })","line":34,"column":21,"nodeType":null,"endLine":34,"endColumn":25},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'load'. Either include it or remove the dependency array.","line":34,"column":31,"nodeType":"ArrayExpression","endLine":34,"endColumn":33,"suggestions":[{"desc":"Update the dependencies array to be: [load]","fix":{"range":[1547,1549],"text":"[load]"}}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useState } from 'react'\r\nimport { motion, AnimatePresence } from 'framer-motion'\r\nimport { createClient } from '@/lib/supabaseClient'\r\nimport toast from 'react-hot-toast'\r\nimport { QuestionWithCategory, AdminCategory } from '@/types/admin'\r\n\r\nconst DIFFICULTIES = ['easy', 'medium', 'hard'] as const\r\nconst DIFF_LABELS: Record<string, string> = { easy: 'в•Әв”Ӯв”ҳГ§в”ҳГӨ', medium: 'в”ҳГ в•ӘВ¬в”ҳГӘв•Әв”Ӯв•Әв•–', hard: 'в•Әв•Ўв•Әв•Јв•ӘВҝ' }\r\n\r\nexport default function AdminQuestionsPage() {\r\n  const supabase = createClient()\r\n  const [questions, setQuestions] = useState<QuestionWithCategory[]>([])\r\n  const [categories, setCategories] = useState<AdminCategory[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n  const [modal, setModal] = useState(false)\r\n  const [editing, setEditing] = useState<QuestionWithCategory | null>(null)\r\n  const [form, setForm] = useState({ category_id: '', difficulty: 'easy' as 'easy'|'medium'|'hard', question: '', answer: '', media_url: '' })\r\n  const [saving, setSaving] = useState(false)\r\n  const [search, setSearch] = useState('')\r\n  const [filterDiff, setFilterDiff] = useState('')\r\n  const [deleteId, setDeleteId] = useState<string | null>(null)\r\n\r\n  async function load() {\r\n    const [q, c] = await Promise.all([\r\n      supabase.from('questions').select('*, categories(name)').order('created_at', { ascending: false }),\r\n      supabase.from('categories').select('*').order('name'),\r\n    ])\r\n    setQuestions(q.data ?? [])\r\n    setCategories(c.data ?? [])\r\n    setLoading(false)\r\n  }\r\n  useEffect(() => { load() }, [])\r\n\r\n  function openAdd() {\r\n    setForm({ category_id: '', difficulty: 'easy', question: '', answer: '', media_url: '' })\r\n    setEditing(null); setModal(true)\r\n  }\r\n  function openEdit(q: QuestionWithCategory) {\r\n    setForm({ category_id: q.category_id ?? '', difficulty: q.difficulty, question: q.question, answer: q.answer, media_url: q.media_url ?? '' })\r\n    setEditing(q); setModal(true)\r\n  }\r\n\r\n  async function save() {\r\n    if (!form.question.trim() || !form.answer.trim()) { toast.error('в•ӘВәв”ҳГӨв•Әв”Ӯв•ӘГұв•ӘВәв”ҳГӨ в”ҳГӘв•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв•ӘВәв•ӘВҝв•ӘвҢҗ в”ҳГ в•Әв•–в”ҳГӨв”ҳГӘв•ӘВҝв•ӘВәв”ҳГҘ'); return }\r\n    setSaving(true)\r\n    const payload = { category_id: form.category_id || null, difficulty: form.difficulty, question: form.question.trim(), answer: form.answer.trim(), media_url: form.media_url.trim() || null }\r\n    const { error } = editing\r\n      ? await supabase.from('questions').update(payload).eq('id', editing.id)\r\n      : await supabase.from('questions').insert(payload)\r\n    if (error) { toast.error(error.message); setSaving(false); return }\r\n    toast.success(editing ? 'в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪ' : 'в•ӘВ¬в”ҳГ в•ӘВ¬ в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ')\r\n    setModal(false); setSaving(false); load()\r\n  }\r\n\r\n  async function del(id: string) {\r\n    const { error } = await supabase.from('questions').delete().eq('id', id)\r\n    if (error) { toast.error(error.message); return }\r\n    toast.success('в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•ӘВЎв•Әв–‘в”ҳГј'); setDeleteId(null); load()\r\n  }\r\n\r\n  const filtered = questions.filter(q =>\r\n    (!search || q.question.includes(search) || q.answer.includes(search)) &&\r\n    (!filterDiff || q.difficulty === filterDiff)\r\n  )\r\n\r\n  return (\r\n    <div className=\"p-8\">\r\n      <div className=\"flex items-center justify-between mb-8\">\r\n        <div>\r\n          <h1 className=\"text-3xl font-black gradient-text-primary\">в•ӘВәв”ҳГӨв•ӘГәв•Әв”Ӯв•ӘВӘв”ҳГӨв•ӘвҢҗ</h1>\r\n          <p style={{ color: 'var(--color-text-secondary)' }}>{questions.length} в•Әв”Ӯв•ӘГұв•ӘВәв”ҳГӨ в”ҳГјв”ҳГЁ в”ҳГ©в•ӘВәв•Әв•Јв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬</p>\r\n        </div>\r\n        <button onClick={openAdd} className=\"btn btn-primary\">+ в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ в•Әв”Ӯв•ӘГұв•ӘВәв”ҳГӨ</button>\r\n      </div>\r\n\r\n      <div className=\"flex gap-3 mb-6 flex-wrap\">\r\n        <input className=\"input max-w-xs\" placeholder=\"вүЎЖ’Г¶Г¬ в•ӘВҝв•ӘВЎв•ӘВҪ...\" value={search} onChange={e => setSearch(e.target.value)} />\r\n        <div className=\"flex gap-2\">\r\n          {['', ...DIFFICULTIES].map(d => (\r\n            <button key={d} onClick={() => setFilterDiff(d)} className=\"btn btn-sm\"\r\n              style={{ background: filterDiff === d ? 'var(--color-primary)' : 'var(--color-surface-2)', color: filterDiff === d ? 'white' : 'var(--color-text-secondary)', border: '1px solid var(--color-border)' }}>\r\n              {d ? DIFF_LABELS[d] : 'в•ӘВәв”ҳГӨв”ҳГўв”ҳГӨ'}\r\n            </button>\r\n          ))}\r\n        </div>\r\n      </div>\r\n\r\n      {loading ? (\r\n        <div className=\"space-y-3\">{Array(6).fill(0).map((_, i) => <div key={i} className=\"h-16 card-glass animate-shimmer rounded-xl\" />)}</div>\r\n      ) : (\r\n        <div className=\"card rounded-2xl overflow-hidden\" style={{ padding: 0 }}>\r\n          <table className=\"w-full text-sm\">\r\n            <thead>\r\n              <tr style={{ background: 'var(--color-surface-2)', borderBottom: '1px solid var(--color-border)' }}>\r\n                {['в•ӘВәв”ҳГӨв•Әв”Ӯв•ӘГұв•ӘВәв”ҳГӨ', 'в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв•ӘВәв•ӘВҝв•ӘвҢҗ', 'в•ӘВәв”ҳГӨв”ҳГјв•ӘВӘв•ӘвҢҗ', 'в•ӘВәв”ҳГӨв•Әв•Ўв•Әв•Јв”ҳГӘв•ӘВҝв•ӘвҢҗ', ''].map(h => (\r\n                  <th key={h} className=\"px-4 py-3 text-right font-bold\" style={{ color: 'var(--color-text-secondary)' }}>{h}</th>\r\n                ))}\r\n              </tr>\r\n            </thead>\r\n            <tbody>\r\n              {filtered.map((q, i) => (\r\n                <tr key={q.id} style={{ borderBottom: '1px solid var(--color-border)', background: i % 2 === 0 ? 'transparent' : 'rgba(255,255,255,0.01)' }}>\r\n                  <td className=\"px-4 py-3 max-w-[200px] truncate\" style={{ color: 'var(--color-text-primary)' }}>{q.question}</td>\r\n                  <td className=\"px-4 py-3 max-w-[160px] truncate\" style={{ color: 'var(--color-text-secondary)' }}>{q.answer}</td>\r\n                  <td className=\"px-4 py-3 text-xs\" style={{ color: 'var(--color-text-muted)' }}>{q.categories?.name ?? 'О“ГҮГ¶'}</td>\r\n                  <td className=\"px-4 py-3\">\r\n                    <span className={`px-2 py-1 rounded-full text-xs font-bold badge-${q.difficulty}`}>{DIFF_LABELS[q.difficulty]}</span>\r\n                  </td>\r\n                  <td className=\"px-4 py-3\">\r\n                    <div className=\"flex gap-2 justify-end\">\r\n                      <button onClick={() => openEdit(q)} className=\"btn btn-sm btn-ghost\" style={{ padding: '4px 12px' }}>в•ӘВ¬в•Әв•Јв•ӘВ»в”ҳГЁв”ҳГӨ</button>\r\n                      <button onClick={() => setDeleteId(q.id)} className=\"btn btn-sm\" style={{ padding: '4px 12px', background: 'rgba(239,68,68,0.1)', color: '#ef4444', border: '1px solid rgba(239,68,68,0.2)' }}>в•ӘВЎв•Әв–‘в”ҳГј</button>\r\n                    </div>\r\n                  </td>\r\n                </tr>\r\n              ))}\r\n              {filtered.length === 0 && <tr><td colSpan={5} className=\"px-4 py-10 text-center\" style={{ color: 'var(--color-text-muted)' }}>в”ҳГӨв•ӘВә в•ӘВ¬в”ҳГӘв•ӘВјв•ӘВ» в”ҳГҘв•ӘВ¬в•ӘВәв•ӘВӘв•ӘВј</td></tr>}\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      )}\r\n\r\n      {/* Add/Edit Modal */}\r\n      <AnimatePresence>\r\n        {modal && (\r\n          <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}\r\n            className=\"fixed inset-0 z-50 flex items-center justify-center p-4\"\r\n            style={{ background: 'rgba(0,0,0,0.75)' }}\r\n            onClick={() => setModal(false)}>\r\n            <motion.div initial={{ scale: 0.9, y: 20 }} animate={{ scale: 1, y: 0 }} exit={{ scale: 0.9 }}\r\n              className=\"card-glass w-full max-w-lg p-8 space-y-5\"\r\n              onClick={e => e.stopPropagation()}>\r\n              <h2 className=\"text-xl font-bold\" style={{ color: 'var(--color-text-primary)' }}>{editing ? 'в•ӘВ¬в•Әв•Јв•ӘВ»в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•Әв”Ӯв•ӘГұв•ӘВәв”ҳГӨ' : 'в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ в•Әв”Ӯв•ӘГұв•ӘВәв”ҳГӨ'}</h2>\r\n              <div>\r\n                <label className=\"label\">в•ӘВәв”ҳГӨв”ҳГјв•ӘВӘв•ӘвҢҗ</label>\r\n                <select className=\"input\" value={form.category_id} onChange={e => setForm(f => ({ ...f, category_id: e.target.value }))}>\r\n                  <option value=\"\">в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в”ҳГјв•ӘВӘв•ӘвҢҗ</option>\r\n                  {categories.map(c => <option key={c.id} value={c.id}>{c.icon} {c.name}</option>)}\r\n                </select>\r\n              </div>\r\n              <div>\r\n                <label className=\"label\">в•ӘВәв”ҳГӨв•Әв•Ўв•Әв•Јв”ҳГӘв•ӘВҝв•ӘвҢҗ</label>\r\n                <div className=\"flex gap-2\">\r\n                  {DIFFICULTIES.map(d => (\r\n                    <button key={d} type=\"button\" onClick={() => setForm(f => ({ ...f, difficulty: d }))}\r\n                      className={`btn btn-sm flex-1 badge-${d}`} style={{ opacity: form.difficulty === d ? 1 : 0.4 }}>\r\n                      {DIFF_LABELS[d]}\r\n                    </button>\r\n                  ))}\r\n                </div>\r\n              </div>\r\n              <div>\r\n                <label className=\"label\">в•ӘВәв”ҳГӨв•Әв”Ӯв•ӘГұв•ӘВәв”ҳГӨ *</label>\r\n                <textarea className=\"input\" rows={3} value={form.question} onChange={e => setForm(f => ({ ...f, question: e.target.value }))} placeholder=\"в•ӘВәв”ҳГўв•ӘВ¬в•ӘВҝ в•ӘВәв”ҳГӨв•Әв”Ӯв•ӘГұв•ӘВәв”ҳГӨ...\" />\r\n              </div>\r\n              <div>\r\n                <label className=\"label\">в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв•ӘВәв•ӘВҝв•ӘвҢҗ *</label>\r\n                <input className=\"input\" value={form.answer} onChange={e => setForm(f => ({ ...f, answer: e.target.value }))} placeholder=\"в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв•ӘВәв•ӘВҝв•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•Ўв•ӘВЎв”ҳГЁв•ӘВЎв•ӘвҢҗ\" />\r\n              </div>\r\n              <div>\r\n                <label className=\"label\">в•Әв–’в•ӘВәв•ӘВҝв•Әв•– в•Әв•Ўв”ҳГӘв•Әв–’в•ӘвҢҗ (в•ӘВәв•ӘВ«в•ӘВ¬в”ҳГЁв•ӘВәв•Әв–’в”ҳГЁ)</label>\r\n                <input className=\"input\" value={form.media_url} onChange={e => setForm(f => ({ ...f, media_url: e.target.value }))} placeholder=\"https://...\" dir=\"ltr\" />\r\n              </div>\r\n              <div className=\"flex gap-3 pt-2\">\r\n                <button onClick={save} disabled={saving} className=\"btn btn-primary flex-1\">{saving ? 'в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•ӘВЎв”ҳГјв•Әв••...' : editing ? 'в•ӘВЎв”ҳГјв•Әв•• в•ӘВәв”ҳГӨв•ӘВ¬в•Әв•Јв•ӘВ»в”ҳГЁв”ҳГӨв•ӘВәв•ӘВ¬' : 'в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ'}</button>\r\n                <button onClick={() => setModal(false)} className=\"btn btn-ghost\">в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ</button>\r\n              </div>\r\n            </motion.div>\r\n          </motion.div>\r\n        )}\r\n      </AnimatePresence>\r\n\r\n      {/* Delete Confirm */}\r\n      <AnimatePresence>\r\n        {deleteId && (\r\n          <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}\r\n            className=\"fixed inset-0 z-50 flex items-center justify-center p-4\"\r\n            style={{ background: 'rgba(0,0,0,0.75)' }}>\r\n            <motion.div initial={{ scale: 0.9 }} animate={{ scale: 1 }} exit={{ scale: 0.9 }}\r\n              className=\"card-glass p-8 max-w-sm w-full text-center space-y-5\">\r\n              <div className=\"text-5xl\">вүЎЖ’Г№ГҰвҲ©в••Г…</div>\r\n              <h3 className=\"text-xl font-bold\" style={{ color: 'var(--color-text-primary)' }}>в•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ» в•ӘВәв”ҳГӨв•ӘВЎв•Әв–‘в”ҳГј</h3>\r\n              <p style={{ color: 'var(--color-text-secondary)' }}>в”ҳГӨв•ӘВә в”ҳГЁв”ҳГ в”ҳГўв”ҳГҘ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв–’в•ӘВәв•ӘВјв•Әв•Ј в•Әв•Јв”ҳГҘ в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨв”ҳГЁв•ӘвҢҗ.</p>\r\n              <div className=\"flex gap-3\">\r\n                <button onClic