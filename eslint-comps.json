toast from 'react-hot-toast'\r\nimport Mascot from '@/components/Mascot'\r\nimport { MascotSettings, MascotPhrase, AnswerPhrase } from '@/types/admin'\r\nimport { MascotState } from '@/types/game'\r\n\r\nconst CATEGORIES = [\r\n  { id: 'intro',      label: 'в•ӘВәв”ҳГӨв•ӘВ¬в•Әв–’в•ӘВЎв”ҳГЁв•ӘВҝ (Intro)',           state: 'idle' },\r\n  { id: 'idle',       label: 'в•ӘВәв”ҳГӨв•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ (Idle)',            state: 'idle' },\r\n  { id: 'correct',    label: 'в•ӘГ‘в•ӘВјв•ӘВәв•ӘВҝв•ӘвҢҗ в•Әв•Ўв•ӘВЎв”ҳГЁв•ӘВЎв•ӘвҢҗ (Correct)',     state: 'correct' },\r\n  { id: 'wrong',      label: 'в•ӘГ‘в•ӘВјв•ӘВәв•ӘВҝв•ӘвҢҗ в•ӘВ«в•ӘВәв•Әв•–в•ӘВӘв•ӘвҢҗ (Wrong)',       state: 'wrong' },\r\n  { id: 'punishment', label: 'в•Әв•Јв”ҳГ©в•ӘВәв•ӘВҝ (Punishment)',          state: 'punishment' },\r\n  { id: 'thinking',   label: 'в•ӘВ¬в”ҳГјв”ҳГўв”ҳГЁв•Әв–’ (Thinking)',           state: 'thinking' },\r\n  { id: 'hype',       label: 'в•ӘВЎв”ҳГ в•ӘВәв•Әв”Ӯ / в•Әв”Ӯв”ҳГӨв•Әв”Ӯв”ҳГӨв•ӘвҢҗ (Hype)',       state: 'hype' },\r\n]\r\n\r\n// Standardized 4-color palette О“ГҮГ¶ same as game\r\nconst DEMO_COLORS = ['#FF3B3B', '#3B82F6', '#A855F7', '#22C55E']\r\n\r\nexport default function AdminMascotPage() {\r\n  const supabase = createClient()\r\n  const [settings, setSettings] = useState<MascotSettings | null>(null)\r\n  const [phrases, setPhrases] = useState<MascotPhrase[]>([])\r\n  const [voices, setVoices] = useState<SpeechSynthesisVoice[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n\r\n  const [showAddModal, setShowAddModal] = useState(false)\r\n  const [newPhrase, setNewPhrase] = useState({ category: 'correct', text: '' })\r\n  const [uploadingAudio, setUploadingAudio] = useState(false)\r\n  const [phraseAudioFile, setPhraseAudioFile] = useState<File | null>(null)\r\n\r\n  // Answer Phrases (shown in QuestionModal after reveal)\r\n  const [answerPhrases, setAnswerPhrases] = useState<AnswerPhrase[]>([])\r\n  const [newAnswerPhrase, setNewAnswerPhrase] = useState<{text: string, category: 'correct'|'wrong'|'punishment'}>({ text: '', category: 'correct' })\r\n  const [addingAnswerCategory, setAddingAnswerCategory] = useState<'correct'|'wrong'|'punishment'|null>(null)\r\n\r\n  const [previewState, setPreviewState] = useState<MascotState>('idle')\r\n  const [isTalking, setIsTalking] = useState(false)\r\n  const [previewColor, setPreviewColor] = useState('#6B9FD4')\r\n\r\n  useEffect(() => {\r\n    async function loadData() {\r\n      const [settsRes, phrsRes] = await Promise.all([\r\n        supabase.from('mascot_settings').select('*').single(),\r\n        supabase.from('mascot_phrases').select('*').order('created_at', { ascending: false }),\r\n      ])\r\n      if (settsRes.data) {\r\n        setSettings(settsRes.data)\r\n        if (settsRes.data.pebble_preview_color) setPreviewColor(settsRes.data.pebble_preview_color)\r\n      }\r\n      if (phrsRes.data) setPhrases(phrsRes.data)\r\n\r\n      // Load answer phrases\r\n      const apRes = await supabase.from('answer_phrases').select('*').order('created_at', { ascending: false })\r\n      if (apRes.data) setAnswerPhrases(apRes.data)\r\n      \r\n      setLoading(false)\r\n    }\r\n    loadData()\r\n\r\n    const loadVoices = () => {\r\n      const v = window.speechSynthesis.getVoices()\r\n      setVoices(v.filter(voice => voice.lang.startsWith('ar') || voice.lang.startsWith('en')))\r\n    }\r\n    loadVoices()\r\n    if (typeof window !== 'undefined' && window.speechSynthesis.onvoiceschanged !== undefined) {\r\n      window.speechSynthesis.onvoiceschanged = loadVoices\r\n    }\r\n  }, [])\r\n\r\n  const saveSettings = async (updates: Partial<MascotSettings>) => {\r\n    if (!settings) return\r\n    const newSettings = { ...settings, ...updates }\r\n    setSettings(newSettings)\r\n    await supabase.from('mascot_settings').update(updates).eq('id', settings.id)\r\n    toast.success('в•ӘВ¬в”ҳГ  в•ӘВЎв”ҳГјв•Әв•• в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬')\r\n  }\r\n\r\n  const addPhrase = async () => {\r\n    if (!newPhrase.text.trim() && !phraseAudioFile) {\r\n      toast.error('в”ҳГЁв•ӘВјв•ӘВҝ в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ в”ҳГҘв•Әв•Ў в•ӘГәв”ҳГӘ в•Әв–’в”ҳГјв•Әв•Ј в”ҳГ в”ҳГӨв”ҳГј в•Әв•Ўв”ҳГӘв•ӘВ¬в”ҳГЁ')\r\n      return\r\n    }\r\n    setUploadingAudio(true)\r\n    let audioUrl = null\r\n    if (phraseAudioFile) {\r\n      const ext = phraseAudioFile.name.split('.').pop()\r\n      const fileName = `${Date.now()}.${ext}`\r\n      const { error: uploadError } = await supabase.storage.from('audio').upload(fileName, phraseAudioFile)\r\n      if (uploadError) { toast.error('в”ҳГјв•Әв”Өв”ҳГӨ в•Әв–’в”ҳГјв•Әв•Ј в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГӘв•ӘВ¬'); setUploadingAudio(false); return }\r\n      const { data: pubData } = supabase.storage.from('audio').getPublicUrl(fileName)\r\n      audioUrl = pubData.publicUrl\r\n    }\r\n    const { data, error } = await supabase.from('mascot_phrases').insert([{\r\n      category: newPhrase.category, text: newPhrase.text, audio_url: audioUrl, is_active: true\r\n    }]).select()\r\n    setUploadingAudio(false)\r\n    if (error) { toast.error('в•ӘВЎв•ӘВ»в•ӘВҪ в•ӘВ«в•Әв•–в•ӘГә') }\r\n    else if (data) {\r\n      setPhrases([data[0], ...phrases])\r\n      setNewPhrase({ category: 'correct', text: '' })\r\n      setPhraseAudioFile(null)\r\n      setShowAddModal(false)\r\n      toast.success('в•ӘВ¬в”ҳГ в•ӘВ¬ в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВјв”ҳГ в”ҳГӨв•ӘвҢҗ')\r\n    }\r\n  }\r\n\r\n  const deletePhrase = async (id: string) => {\r\n    await supabase.from('mascot_phrases').delete().eq('id', id)\r\n    setPhrases(phrases.filter(p => p.id !== id))\r\n    toast.success('в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•ӘВЎв•Әв–‘в”ҳГј')\r\n  }\r\n\r\n  const addAnswerPhrase = async (category: 'correct'|'wrong'|'punishment') => {\r\n    if (!newAnswerPhrase.text.trim()) return\r\n    const { data, error } = await supabase.from('answer_phrases').insert([{\r\n      category, text: newAnswerPhrase.text.trim(), is_active: true\r\n    }]).select()\r\n    if (error) { toast.error('в•ӘВЎв•ӘВ»в•ӘВҪ в•ӘВ«в•Әв•–в•ӘГә'); return }\r\n    if (data) {\r\n      setAnswerPhrases(prev => [data[0], ...prev])\r\n      setNewAnswerPhrase({ text: '', category: 'correct' })\r\n      setAddingAnswerCategory(null)\r\n      toast.success('в•ӘВ¬в”ҳГ в•ӘВ¬ в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВјв”ҳГ в”ҳГӨв•ӘвҢҗ')\r\n    }\r\n  }\r\n\r\n  const deleteAnswerPhrase = async (id: string) => {\r\n    await supabase.from('answer_phrases').delete().eq('id', id)\r\n    setAnswerPhrases(prev => prev.filter(p => p.id !== id))\r\n    toast.success('в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•ӘВЎв•Әв–‘в”ҳГј')\r\n  }\r\n\r\n  const testPhrase = (phrase: MascotPhrase) => {\r\n    setPreviewState(phrase.category === 'intro' ? 'idle' : phrase.category as MascotState)\r\n    \r\n    const sequence: any[] = []\r\n    \r\n    const config = settings?.timing_config || {}\r\n    const delayCorrect = Math.min(Math.max(config.correct ?? 350, 150), 700)\r\n    const delayWrong = Math.min(Math.max(config.wrong ?? 250, 100), 600)\r\n    const delayReveal = Math.min(Math.max(config.reveal ?? 400, 200), 900)\r\n\r\n    // Add AAA Game Show Pacing (SFX -> Delay)\r\n    if (phrase.category === 'correct' || phrase.category === 'hype') {\r\n      sequence.push({ kind: 'sfx', type: 'correct' })\r\n      sequence.push({ kind: 'wait', durationMs: delayCorrect })\r\n    } else if (phrase.category === 'wrong' || phrase.category === 'punishment') {\r\n      sequence.push({ kind: 'sfx', type: 'wrong' })\r\n      sequence.push({ kind: 'wait', durationMs: delayWrong })\r\n    } else if (phrase.category === 'thinking') {\r\n      sequence.push({ kind: 'sfx', type: 'reveal' })\r\n      sequence.push({ kind: 'wait', durationMs: delayReveal })\r\n    }\r\n\r\n    sequence.push({ kind: 'hook', fn: () => setIsTalking(true) })\r\n\r\n    if (phrase.audio_url) {\r\n      sequence.push({ kind: 'mp3', url: phrase.audio_url })\r\n    } else {\r\n      const pitch = settings ? 1.0 + (settings.energy_level - 50) * 0.01 : 1.1\r\n      const rate = settings ? 1.0 + (settings.energy_level - 50) * 0.005 : 1.1\r\n      sequence.push({ kind: 'tts', text: phrase.text, pitch, rate })\r\n    }\r\n\r\n    sequence.push({ kind: 'hook', fn: () => setIsTalking(false) })\r\n    sequence.push({ kind: 'wait', durationMs: 1000 })\r\n    sequence.push({ kind: 'hook', fn: () => setPreviewState('idle') })\r\n\r\n    // Play via Director to test the queue/interrupt rules\r\n    import('@/lib/audioDirector').then(({ audioDirector }) => {\r\n      audioDirector.runSequence(sequence, { priority: 'interrupt', atomicMode: 'cancel' })\r\n    })\r\n  }\r\n\r\n  if (loading) return <div className=\"p-8 text-center text-white/50\">в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ...</div>\r\n\r\n  return (\r\n    <div className=\"p-8 max-w-6xl mx-auto space-y-12\">\r\n      <div>\r\n        <h1 className=\"text-4xl font-black gradient-text-primary\">в•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв”Өв•ӘВ«в•Әв•Ўв”ҳГЁв•ӘвҢҗ (в•ӘВҝв”ҳГЁв•ӘВҝв”ҳГӨ) в”ҳГӘв•ӘВәв”ҳГӨв•ӘГәв•Әв•Ўв”ҳГӘв•ӘВәв•ӘВ¬</h1>\r\n        <p className=\"text-white/50 mt-2\">в•ӘВ¬в•ӘВЎв”ҳГўв”ҳГ  в”ҳГјв”ҳГЁ в•Әв”Өв•ӘВ«в•Әв•Ўв”ҳГЁв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВҝв”ҳГӨв•ӘГ® в•Әв–’в•ӘВ»в”ҳГӘв•ӘВ» в•ӘВәв”ҳГӨв•ӘГәв”ҳГјв•Әв•Јв•ӘВәв”ҳГӨв•ӘГ® в”ҳГӘв•ӘВәв”ҳГӨв•Әв•Јв•ӘВҝв•ӘВәв•Әв–’в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГӘв•ӘВ¬в”ҳГЁв•ӘвҢҗ.</p>\r\n      </div>\r\n\r\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-8\">\r\n\r\n        {/* О“Г¶ГҮО“Г¶ГҮ LEFT: Pebble Preview + Style О“Г¶ГҮО“Г¶ГҮ */}\r\n        <div className=\"lg:col-span-1 space-y-6\">\r\n\r\n          {/* Live Pebble Preview */}\r\n          <div className=\"card-glass p-8 flex flex-col items-center justify-center relative overflow-hidden min-h-[320px]\">\r\n            <div className=\"absolute inset-0 bg-gradient-to-br from-purple-500/10 to-cyan-500/10\" />\r\n            <Mascot state={previewState} size={170} isTalking={isTalking} color={previewColor} className=\"z-10\" />\r\n            <div className=\"mt-6 flex gap-2 flex-wrap justify-center relative z-10\">\r\n              {(['idle','correct','wrong','hype','thinking','angry','punishment'] as const).map(s => (\r\n                <button\r\n                  key={s}\r\n                  onClick={() => setPreviewState(s)}\r\n                  className={`px-3 py-1 rounded-full text-xs font-bold transition-all border ${previewState === s ? 'bg-white/20 border-white/40 text-white' : 'bg-white/5 border-white/10 text-white/50 hover:bg-white/10'}`}\r\n                >{s}</button>\r\n              ))}\r\n            </div>\r\n          </div>\r\n\r\n          {/* Color Palette */}\r\n          <div className=\"card-glass p-6 space-y-4\">\r\n            <h3 className=\"font-bold text-lg border-b border-white/10 pb-3\">в”ҳГӨв”ҳГӘв”ҳГҘ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВҝв”ҳГӨ в”ҳГӨв”ҳГӨв”ҳГ в•Әв•Јв•ӘВәв”ҳГЁв”ҳГҘв•ӘвҢҗ</h3>\r\n            <p className=\"text-xs text-white/40\">в”ҳГјв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГӨв•Әв•Јв•ӘВҝв•ӘвҢҗв•ӘГ® в”ҳГЁв•ӘГәв•ӘВ«в•Әв–‘ в”ҳГўв”ҳГӨ в•ӘВҝв”ҳГЁв•ӘВҝв”ҳГӨ в”ҳГӨв”ҳГӘв”ҳГҘ в”ҳГјв•Әв–’в”ҳГЁв”ҳГ©в”ҳГ§ в•ӘВ¬в”ҳГӨв”ҳГ©в•ӘВәв•ӘВӘв”ҳГЁв•ӘВәв”ҳГҜ.</p>\r\n            <div className=\"flex flex-wrap gap-3 mt-3\">\r\n              {DEMO_COLORS.map(c => (\r\n                <button\r\n                  key={c}\r\n                  onClick={() => setPreviewColor(c)}\r\n                  className={`w-9 h-9 rounded-full transition-all border-2 ${previewColor === c ? 'border-white scale-110' : 'border-transparent scale-100'}`}\r\n                  style={{ background: c, boxShadow: previewColor === c ? `0 0 16px ${c}` : 'none' }}\r\n                />\r\n              ))}\r\n            </div>\r\n            <div className=\"flex items-center gap-3 mt-2\">\r\n              <label className=\"text-sm text-white/60\">в”ҳГӨв”ҳГӘв”ҳГҘ в”ҳГ в•ӘВ«в•Әв•Ўв•Әв•Ў:</label>\r\n              <input\r\n                type=\"color\"\r\n                value={previewColor}\r\n                onChange={e => setPreviewColor(e.target.value)}\r\n                className=\"w-10 h-10 rounded-lg border border-white/20 bg-transparent cursor-pointer\"\r\n              />\r\n              <span className=\"font-mono text-sm text-white/50\">{previewColor}</span>\r\n            </div>\r\n          </div>\r\n\r\n          {/* Global Settings */}\r\n          {settings && (\r\n            <div className=\"card-glass p-6 space-y-5\">\r\n              <h3 className=\"font-bold text-xl border-b border-white/10 pb-4\">в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•Әв•Јв•ӘВәв”ҳГ в•ӘвҢҗ</h3>\r\n              <label className=\"flex items-center justify-between cursor-pointer\">\r\n                <span className=\"font-bold\">в•ӘВ¬в”ҳГјв•Әв•Јв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•Әв”Өв•ӘВ«в•Әв•Ўв”ҳГЁв•ӘвҢҗ в”ҳГјв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГӨв•Әв•Јв•ӘВҝв•ӘвҢҗ</span>\r\n                <input type=\"checkbox\" checked={settings.enabled} onChange={e => saveSettings({ enabled: e.target.checked })} className=\"toggle\" />\r\n              </label>\r\n              <label className=\"flex items-center justify-between cursor-pointer\">\r\n                <span className=\"font-bold\">в•ӘВ¬в”ҳГјв•Әв•Јв”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГӘв•ӘВ¬ (TTS)</span>\r\n                <input type=\"checkbox\" checked={settings.voice_enabled} onChange={e => saveSettings({ voice_enabled: e.target.checked })} className=\"toggle\" />\r\n              </label>\r\n              <div>\r\n                <label className=\"text-sm font-bold text-white/70 mb-2 block\">в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГӘв”ҳГ« в•ӘВәв”ҳГӨв•Әв•–в•ӘВәв”ҳГ©в•ӘвҢҗ ({settings.energy_level}%)</label>\r\n                <input type=\"range\" min=\"0\" max=\"100\" value={settings.energy_level} onChange={e => saveSettings({ energy_level: parseInt(e.target.value) })} className=\"w-full accent-primary\" />\r\n              </div>\r\n            </div>\r\n          )}\r\n\r\n          {/* Audio Engine Pacing Settings */}\r\n          {settings && (\r\n            <div className=\"card-glass p-6 space-y-5\">\r\n              <h3 className=\"font-bold text-xl border-b border-white/10 pb-4\">в•ӘВ¬в”ҳГӘв”ҳГ©в”ҳГЁв•ӘВ¬ в”ҳГӘв•ӘГ‘в”ҳГЁв”ҳГ©в•ӘВәв•Әв•Ј в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГӘв•ӘВ¬ (TV Show Pacing)</h3>\r\n              \r\n              <div>\r\n                <label className=\"text-sm font-bold text-white/70 mb-2 flex justify-between\">\r\n                  <span>в•ӘВ¬в•ӘГәв•ӘВ«в”ҳГЁв•Әв–’ в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв•ӘВәв•ӘВҝв•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•Ўв•ӘВЎв”ҳГЁв•ӘВЎв•ӘвҢҗ (ms)</span>\r\n                  <span>{settings.timing_config?.correct ?? 350}ms</span>\r\n                </label>\r\n                <input type=\"range\" min=\"150\" max=\"700\" value={settings.timing_config?.correct ?? 350} onChange={e => saveSettings({ timing_config: { ...settings.timing_config, correct: parseInt(e.target.value) } })} className=\"w-full accent-primary\" />\r\n              </div>\r\n              \r\n              <div>\r\n                <label className=\"text-sm font-bold text-white/70 mb-2 flex justify-between\">\r\n                  <span>в•ӘВ¬в•ӘГәв•ӘВ«в”ҳГЁв•Әв–’ в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв•ӘВәв•ӘВҝв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ«в•ӘВәв•Әв•–в•ӘВӘв•ӘвҢҗ (ms)</span>\r\n                  <span>{settings.timing_config?.wrong ?? 250}ms</span>\r\n                </label>\r\n                <input type=\"range\" min=\"100\" max=\"600\" value={settings.timing_config?.wrong ?? 250} onChange={e => saveSettings({ timing_config: { ...settings.timing_config, wrong: parseInt(e.target.value) } })} className=\"w-full accent-primary\" />\r\n              </div>\r\n\r\n              <div>\r\n                <label className=\"text-sm font-bold text-white/70 mb-2 flex justify-between\">\r\n                  <span>в•ӘВ¬в•ӘГәв•ӘВ«в”ҳГЁв•Әв–’ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГјв”ҳГўв”ҳГЁв•Әв–’ / в”ҳГўв•Әв”Өв”ҳГј в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВјв•ӘВәв•ӘВҝв•ӘвҢҗ (ms)</span>\r\n                  <span>{settings.timing_config?.reveal ?? 400}ms</span>\r\n                </label>\r\n                <input type=\"range\" min=\"200\" max=\"900\" value={settings.timing_config?.reveal ?? 400} onChange={e => saveSettings({ timing_config: { ...settings.timing_config, reveal: parseInt(e.target.value) } })} className=\"w-full accent-primary\" />\r\n              </div>\r\n\r\n              <div>\r\n                <label className=\"text-sm font-bold text-white/70 mb-2 block\">в”ҳГӨв”ҳГ§в•ӘВјв•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГӘв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в”ҳГјв•Әв•ўв”ҳГӨв•ӘвҢҗ (Fallback)</label>\r\n                <select \r\n                  className=\"input w-full\"\r\n                  value={settings.timing_config?.voice_lang ?? 'ar-SA'}\r\n                  onChange={e => saveSettings({ timing_config: { ...settings.timing_config, voice_lang: e.target.value } })}\r\n                >\r\n                  <option value=\"ar-SA\">в•ӘВәв”ҳГӨв•Әв”Ӯв•Әв•Јв”ҳГӘв•ӘВ»в”ҳГЁв•ӘвҢҗ (ar-SA)</option>\r\n                  <option value=\"ar-EG\">в”ҳГ в•Әв•Ўв•Әв–’ (ar-EG)</option>\r\n                  <option value=\"ar-AE\">в•ӘВәв”ҳГӨв•ӘГ‘в”ҳГ в•ӘВәв•Әв–’в•ӘВәв•ӘВ¬ (ar-AE)</option>\r\n                </select>\r\n              </div>\r\n            </div>\r\n          )}\r\n        </div>\r\n\r\n        {/* О“Г¶ГҮО“Г¶ГҮ RIGHT: Phrases List О“Г¶ГҮО“Г¶ГҮ */}\r\n        <div className=\"lg:col-span-2 space-y-6\">\r\n          <div className=\"flex items-center justify-between bg-white/5 p-5 rounded-2xl border border-white/10\">\r\n            <div>\r\n              <h2 className=\"text-2xl font-black\">в•ӘВәв”ҳГӨв•Әв•Јв•ӘВҝв•ӘВәв•Әв–’в•ӘВәв•ӘВ¬ в”ҳГӘв•ӘВәв”ҳГӨв•ӘГәв•Әв•Ўв”ҳГӘв•ӘВәв•ӘВ¬</h2>\r\n              <p className=\"text-white/40 text-sm mt-1\">{phrases.length} в•Әв•Јв•ӘВҝв•ӘВәв•Әв–’в•ӘвҢҗ в”ҳГ в•Әв”Ӯв•ӘВјв”ҳГӨв•ӘвҢҗ</p>\r\n            </div>\r\n            <button onClick={() => setShowAddModal(true)} className=\"btn btn-primary\">+ в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ в•Әв•Јв•ӘВҝв•ӘВәв•Әв–’в•ӘвҢҗ</button>\r\n          </div>\r\n\r\n          <div className=\"grid gap-4\">\r\n            {CATEGORIES.map(cat => {\r\n              const catPhrases = phrases.filter(p => p.category === cat.id)\r\n              if (catPhrases.length === 0) return null\r\n              return (\r\n                <div key={cat.id} className=\"card-glass p-0 overflow-hidden\">\r\n                  <div className=\"bg-white/5 px-6 py-3 border-b border-white/10 flex items-center gap-3\">\r\n                    <Mascot state={cat.state as any} size={32} color={previewColor} className=\"flex-shrink-0\" />\r\n                    <span className=\"font-bold text-sm tracking-widest uppercase\">{cat.label}</span>\r\n                  </div>\r\n                  <div className=\"divide-y divide-white/5\">\r\n                    {catPhrases.map(p => (\r\n                      <div key={p.id} className=\"p-4 flex items-center justify-between hover:bg-white/[0.02] transition-colors\">\r\n                        <div>\r\n                          <p className=\"font-medium text-lg\">{p.text || <span className=\"text-white/30 italic\">в•Әв•Ўв”ҳГӘв•ӘВ¬ в”ҳГјв”ҳГ©в•Әв•– (в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в”ҳГҘв•Әв•Ў)</span>}</p>\r\n                          {p.audio_url && <span className=\"text-xs text-green-400 bg-green-400/10 px-2 py-0.5 rounded mt-1 inline-block\">вүЎЖ’Г„Гұ в•Әв•Ўв”ҳГӘв•ӘВ¬ в”ҳГ в•ӘВ«в•Әв•Ўв•Әв•Ў в”ҳГ в•ӘВ¬в•ӘВәв•ӘВЎ</span>}\r\n                        </div>\r\n                        <div className=\"flex gap-2\">\r\n                          <button onClick={() => testPhrase(p)} className=\"w-10 h-10 flex items-center justify-center rounded-full bg-primary/20 text-primary hover:bg-primary hover:text-white transition-colors\">О“Г»в•ў</button>\r\n                          <button onClick={() => deletePhrase(p.id)} className=\"w-10 h-10 flex items-center justify-center rounded-full bg-red-500/20 text-red-500 hover:bg-red-500 hover:text-white transition-colors\">вүЎЖ’Г№ГҰ</button>\r\n                        </div>\r\n                      </div>\r\n                    ))}\r\n                  </div>\r\n                </div>\r\n       