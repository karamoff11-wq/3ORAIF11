replaced О“ГҝГЎвҲ©в••Г… (contains hidden ZWJ \\u200D О“ГҮГ¶ crashes SWC parser) with plain anchor emoji\n  { id: 'cat-anime-op',       topic_id: 'topic-anime',     name: 'One Piece',            icon: 'О“ГңГҙ' },\n  { id: 'cat-anime-dn',       topic_id: 'topic-anime',     name: 'Death Note',           icon: 'вүЎЖ’ГҙГҙ' },\n  { id: 'cat-anime-hxh',      topic_id: 'topic-anime',     name: 'Hunter x Hunter',      icon: 'вүЎЖ’Г„Гә' },\n  { id: 'cat-anime-dbz',      topic_id: 'topic-anime',     name: 'Dragon Ball Z',        icon: 'вүЎЖ’ГүГ«' },\n  { id: 'cat-anime-ds',       topic_id: 'topic-anime',     name: 'Demon Slayer',         icon: 'вүЎЖ’Г№ГӯвҲ©в••Г…' },\n  { id: 'cat-anime-jjk',      topic_id: 'topic-anime',     name: 'Jujutsu Kaisen',       icon: 'О“ВЈГЁ' },\n  { id: 'cat-anime-fma',      topic_id: 'topic-anime',     name: 'Fullmetal Alchemist',  icon: 'вүЎЖ’ВӘв•ӣ' },\n  { id: 'cat-anime-bleach',   topic_id: 'topic-anime',     name: 'Bleach',               icon: 'вүЎЖ’ГҰв•—' },\n  { id: 'cat-game-gta',       topic_id: 'topic-videogames', name: 'GTA V',               icon: 'вүЎЖ’ГңГ№' },\n  { id: 'cat-game-fifa',      topic_id: 'topic-videogames', name: 'FIFA',                icon: 'О“Гңв•ң' },\n  { id: 'cat-game-mc',        topic_id: 'topic-videogames', name: 'Minecraft',           icon: 'вүЎЖ’Вәв–’' },\n  { id: 'cat-game-witcher',   topic_id: 'topic-videogames', name: 'The Witcher 3',       icon: 'вүЎЖ’Гүв•‘' },\n  { id: 'cat-game-rdr2',      topic_id: 'topic-videogames', name: 'Red Dead 2',          icon: 'вүЎЖ’ГұГЎ' },\n  { id: 'cat-game-cod',       topic_id: 'topic-videogames', name: 'Call of Duty',        icon: 'вүЎЖ’Г¶ВҪ' },\n  { id: 'cat-game-csgo',      topic_id: 'topic-videogames', name: 'CS:GO',               icon: 'вүЎЖ’ГҶГә' },\n  { id: 'cat-game-lol',       topic_id: 'topic-videogames', name: 'League of Legends',   icon: 'вүЎЖ’Г…ГҘ' },\n  { id: 'cat-game-zelda',     topic_id: 'topic-videogames', name: 'Zelda: BOTW',         icon: 'вүЎЖ’ВәВҘ' },\n  { id: 'cat-game-gow',       topic_id: 'topic-videogames', name: 'God of War',          icon: 'вүЎЖ’В¬Гҙ' },\n]\n\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n// Component\n// О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\nexport default function AdminTopicsPage() {\n  const supabase = createClient()\n\n  const [topics,   setTopics]   = useState<Topic[]>([])\n  const [loading,  setLoading]  = useState(true)\n  const [modal,    setModal]    = useState(false)\n  const [editing,  setEditing]  = useState<Topic | null>(null)\n  const [saving,   setSaving]   = useState(false)\n  const [uploading,setUploading]= useState(false)\n  const [deleteId, setDeleteId] = useState<string | null>(null)\n\n  const [cropEditorUrl, setCropEditorUrl] = useState<string | null>(null)\n  const [cropConfig,    setCropConfig]    = useState<CropConfig | null>(null)\n\n  const [form, setForm] = useState({\n    id:          '',\n    name:        '',\n    icon:        'вүЎЖ’ГҙГ©',\n    color:       '#8b5cf6',\n    order_index: 0,\n    video_url:   '',\n    bg_style:    'bg-gradient-to-br from-gray-900 to-black',\n  })\n\n  // О“Г¶ГҮО“Г¶ГҮ Load О“Г¶ГҮО“Г¶ГҮ\n  async function load() {\n    setLoading(true)\n    try {\n      const [topicsRes, catsRes] = await Promise.all([\n        supabase.from('topics').select('*').order('order_index'),\n        supabase.from('categories').select('*'),\n      ])\n\n      let rawTopics: any[] = topicsRes.data ?? []\n      let rawCats:   any[] = catsRes.data   ?? []\n\n      // Use fallback if DB is empty\n      if (rawTopics.length === 0) {\n        rawTopics = FALLBACK_TOPICS\n        rawCats   = FALLBACK_CATS\n      }\n\n      const merged = rawTopics.map(topic => ({\n        ...topic,\n        categories: rawCats.filter(c => c.topic_id === topic.id),\n      }))\n\n      setTopics(merged)\n    } catch (err: any) {\n      toast.error(err?.message ?? 'Failed to load topics')\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  useEffect(() => { load() }, []) // eslint-disable-line react-hooks/exhaustive-deps\n\n  // О“Г¶ГҮО“Г¶ГҮ Open add modal О“Г¶ГҮО“Г¶ГҮ\n  function openAdd() {\n    setForm({\n      id:          `topic-${Date.now()}`,\n      name:        '',\n      icon:        'вүЎЖ’ГҙГ©',\n      color:       '#8b5cf6',\n      order_index: topics.length + 1,\n      video_url:   '',\n      bg_style:    'bg-gradient-to-br from-gray-900 to-black',\n    })\n    setCropConfig(null)\n    setEditing(null)\n    setModal(true)\n  }\n\n  // О“Г¶ГҮО“Г¶ГҮ Open edit modal О“Г¶ГҮО“Г¶ГҮ\n  function openEdit(tp: Topic) {\n    setForm({\n      id:          tp.id,\n      name:        tp.name        ?? '',\n      icon:        tp.icon        ?? 'вүЎЖ’ГҙГ©',\n      color:       tp.color       ?? '#8b5cf6',\n      order_index: tp.order_index ?? 0,\n      video_url:   tp.video_url   ?? '',\n      bg_style:    tp.bg_style    ?? 'bg-gradient-to-br from-gray-900 to-black',\n    })\n    setCropConfig(tp.crop_config ?? null)\n    setEditing(tp)\n    setModal(true)\n  }\n\n  // О“Г¶ГҮО“Г¶ГҮ Video upload О“Г¶ГҮО“Г¶ГҮ\n  async function handleVideoUpload(e: React.ChangeEvent<HTMLInputElement>) {\n    const file = e.target.files?.[0]\n    if (!file) return\n    setUploading(true)\n    const ext      = file.name.split('.').pop()\n    const fileName = `${Date.now()}-${Math.random().toString(36).slice(2)}.${ext}`\n    const filePath = `backgrounds/${fileName}`\n    try {\n      const { error: uploadError } = await supabase.storage.from('videos').upload(filePath, file)\n      if (uploadError) throw uploadError\n      const { data } = supabase.storage.from('videos').getPublicUrl(filePath)\n      setForm(f => ({ ...f, video_url: data.publicUrl }))\n      setCropEditorUrl(data.publicUrl)\n      toast.success('в•ӘВ¬в”ҳГ  в•Әв–’в”ҳГјв•Әв•Ј в•ӘВәв”ҳГӨв”ҳГјв”ҳГЁв•ӘВ»в”ҳГЁв”ҳГӘ в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ! в•ӘВәв•Әв•ўв•ӘВҝв•Әв•– в•ӘВәв”ҳГӨв”ҳГ©в•Әв•Ў в•ӘВәв”ҳГӨв•ӘГів”ҳГҘ.')\n    } catch (err: any) {\n      toast.error('в•ӘВ«в•Әв•–в•ӘГә в”ҳГјв”ҳГЁ в•ӘВәв”ҳГӨв•Әв–’в”ҳГјв•Әв•Ј: ' + err.message)\n    } finally {\n      setUploading(false)\n    }\n  }\n\n  // О“Г¶ГҮО“Г¶ГҮ Save О“Г¶ГҮО“Г¶ГҮ\n  async function save() {\n    if (!form.name.trim()) { toast.error('в•ӘВәв•Әв”Ӯв”ҳГ  в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•Әв•ўв”ҳГӘв•Әв•Ј в”ҳГ в•Әв•–в”ҳГӨв”ҳГӘв•ӘВҝ'); return }\n    setSaving(true)\n    const payload = {\n      id:          form.id,\n      name:        form.name.trim(),\n      icon:        form.icon,\n      color:       form.color,\n      order_index: form.order_index,\n      video_url:   form.video_url,\n      bg_style:    form.bg_style,\n      crop_config: cropConfig ?? null,\n    }\n    const { error } = editing\n      ? await supabase.from('topics').update(payload).eq('id', editing.id)\n      : await supabase.from('topics').insert(payload)\n    if (error) { toast.error(error.message); setSaving(false); return }\n    toast.success(editing ? 'в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪ' : 'в•ӘВ¬в”ҳГ в•ӘВ¬ в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ')\n    setModal(false)\n    setSaving(false)\n    load()\n  }\n\n  // О“Г¶ГҮО“Г¶ГҮ Delete О“Г¶ГҮО“Г¶ГҮ\n  async function del(id: string) {\n    const { error } = await supabase.from('topics').delete().eq('id', id)\n    if (error) { toast.error(error.message); return }\n    toast.success('в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•ӘВЎв•Әв–‘в”ҳГј')\n    setDeleteId(null)\n    load()\n  }\n\n  // О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n  // Render\n  // О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n  return (\n    <div className=\"p-8\">\n\n      {/* Header */}\n      <div className=\"flex items-center justify-between mb-8\">\n        <div>\n          <h1 className=\"text-3xl font-black gradient-text-primary\">в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•ӘВәв•Әв•ўв”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв•Әв–’в•ӘВӘв”ҳГЁв•Әв”Ӯв”ҳГЁв•ӘвҢҗ</h1>\n          <p style={{ color: 'var(--color-text-secondary)' }}>{topics.length} в”ҳГ в”ҳГӘв•Әв•ўв”ҳГӘв•Әв•Ј</p>\n        </div>\n        <button onClick={openAdd} className=\"btn btn-primary\">+ в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ в”ҳГ в”ҳГӘв•Әв•ўв”ҳГӘв•Әв•Ј</button>\n      </div>\n\n      {/* Topics grid */}\n      {loading ? (\n        <div className=\"grid grid-cols-2 md:grid-cols-3 gap-4\">\n          {Array(6).fill(0).map((_, i) => (\n            <div key={i} className=\"h-28 card-glass animate-shimmer rounded-2xl\" />\n          ))}\n        </div>\n      ) : (\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4\">\n          {topics.map((tp, i) => (\n            <motion.div\n              key={tp.id}\n              initial={{ opacity: 0, y: 16 }}\n              animate={{ opacity: 1, y: 0 }}\n              transition={{ delay: i * 0.05 }}\n              className=\"card-glass flex items-center gap-4 relative overflow-hidden\"\n            >\n              {tp.video_url && (\n                <video\n                  src={tp.video_url}\n                  autoPlay loop muted playsInline\n                  className=\"absolute inset-0 w-full h-full object-cover opacity-20 z-0 pointer-events-none\"\n                />\n              )}\n              <div className=\"absolute top-0 bottom-0 right-0 w-1 z-10\" style={{ backgroundColor: tp.color ?? '#8b5cf6' }} />\n\n              <div\n                className=\"text-4xl w-14 h-14 rounded-2xl flex items-center justify-center shrink-0 mr-2 z-10 relative\"\n                style={{ background: `${tp.color ?? '#8b5cf6'}20` }}\n              >\n                {tp.icon}\n              </div>\n\n              <div className=\"flex-1 min-w-0 z-10 relative\">\n                <div className=\"font-bold truncate text-lg\" style={{ color: 'var(--color-text-primary)' }}>\n                  {tp.name}\n                </div>\n                <div className=\"flex flex-wrap gap-1 mt-2\">\n                  {tp.categories && tp.categories.length > 0 ? (\n                    tp.categories.map((cat: any) => (\n                      <span\n                        key={cat.id}\n                        className=\"text-[10px] px-2 py-1 rounded-md flex items-center gap-1\"\n                        style={{ background: 'var(--color-surface-3)', color: 'var(--color-text-secondary)' }}\n                      >\n                        <span>{cat.icon}</span>\n                        <span>{cat.name}</span>\n                      </span>\n                    ))\n                  ) : (\n                    <span\n                      className=\"text-[10px] px-2 py-1 rounded-md\"\n                      style={{ background: 'rgba(239,68,68,0.1)', color: '#ef4444' }}\n                    >\n                      в”ҳГӨв•ӘВә в•ӘВ¬в”ҳГӘв•ӘВјв•ӘВ» в”ҳГјв•ӘВӘв•ӘВәв•ӘВ¬\n                    </span>\n                  )}\n                </div>\n              </div>\n\n              <div className=\"flex flex-col gap-1 z-10 relative\">\n                <button\n                  onClick={() => openEdit(tp)}\n                  className=\"btn btn-sm btn-ghost\"\n                  style={{ padding: '4px 10px', fontSize: '12px' }}\n                >\n                  в•ӘВ¬в•Әв•Јв•ӘВ»в”ҳГЁв”ҳГӨ\n                </button>\n                <button\n                  onClick={() => setDeleteId(tp.id)}\n                  className=\"btn btn-sm\"\n                  style={{ padding: '4px 10px', fontSize: '12px', background: 'rgba(239,68,68,0.1)', color: '#ef4444', border: '1px solid rgba(239,68,68,0.2)' }}\n                >\n                  в•ӘВЎв•Әв–‘в”ҳГј\n                </button>\n              </div>\n            </motion.div>\n          ))}\n\n          {topics.length === 0 && (\n            <div className=\"col-span-3 py-16 text-center\" style={{ color: 'var(--color-text-muted)' }}>\n              в”ҳГӨв•ӘВә в•ӘВ¬в”ҳГӘв•ӘВјв•ӘВ» в”ҳГ в”ҳГӘв•ӘВәв•Әв•ўв”ҳГЁв•Әв•Ј в•ӘВҝв•Әв•Јв•ӘВ» О“ГҮГ¶ в•ӘГәв•Әв•ўв”ҳГј в”ҳГ в”ҳГӘв•Әв•ўв”ҳГӘв•Әв•Ј в•ӘВјв•ӘВ»в”ҳГЁв•ӘВ»\n            </div>\n          )}\n        </div>\n      )}\n\n      {/* О“Г¶ГҮО“Г¶ГҮ Add / Edit Modal О“Г¶ГҮО“Г¶ГҮ */}\n      <AnimatePresence>\n        {modal && (\n          <motion.div\n            initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}\n            className=\"fixed inset-0 z-50 flex items-center justify-center p-4\"\n            style={{ background: 'rgba(0,0,0,0.7)' }}\n            onClick={() => setModal(false)}\n          >\n            <motion.div\n              initial={{ scale: 0.9, y: 20 }} animate={{ scale: 1, y: 0 }} exit={{ scale: 0.9 }}\n              className=\"card-glass w-full max-w-sm p-8 space-y-5 max-h-[90vh] overflow-y-auto\"\n              onClick={e => e.stopPropagation()}\n            >\n              <h2 className=\"text-xl font-bold\" style={{ color: 'var(--color-text-primary)' }}>\n                {editing ? 'в•ӘВ¬в•Әв•Јв•ӘВ»в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•Әв•ўв”ҳГӘв•Әв•Ј' : 'в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ в”ҳГ в”ҳГӘв•Әв•ўв”ҳГӘв•Әв•Ј в•ӘВјв•ӘВ»в”ҳГЁв•ӘВ»'}\n              </h2>\n\n              {/* Name */}\n              <div>\n                <label className=\"label\">в•ӘВәв•Әв”Ӯв”ҳГ  в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•Әв•ўв”ҳГӘв•Әв•Ј *</label>\n                <input\n                  className=\"input\"\n                  value={form.name}\n                  onChange={e => setForm(f => ({ ...f, name: e.target.value }))}\n                  placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в•ӘВјв•Әв•‘в•Әв–’в•ӘВәв”ҳГјв”ҳГЁв•ӘВә\"\n                />\n              </div>\n\n              {/* ID (add only) */}\n              {!editing && (\n                <div>\n                  <label className=\"label\">в•ӘВәв”ҳГӨв”ҳГ в•Әв•Јв•Әв–’в”ҳГј (ID)</label>\n                  <input\n                    className=\"input\"\n                    value={form.id}\n                    onChange={e => setForm(f => ({ ...f, id: e.target.value }))}\n                    placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: topic-geography\"\n                  />\n                  <p className=\"text-[10px] text-white/50 mt-1\">в”ҳГЁв”ҳГјв•Әв•ўв”ҳГӨ в•ӘГәв”ҳГҘ в”ҳГЁв”ҳГўв”ҳГӘв”ҳГҘ в•ӘВҝв•ӘВәв”ҳГӨв”ҳГӨв•Әв•‘в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘГ‘в”ҳГҘв•ӘВјв”ҳГӨв”ҳГЁв•Әв–“в”ҳГЁв•ӘвҢҗ в”ҳГӘв•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в”ҳГ в•Әв”Ӯв•ӘВәв”ҳГјв•ӘВәв•ӘВ¬.</p>\n                </div>\n              )}\n\n              {/* Order */}\n              <div>\n                <label className=\"label\">в•ӘВәв”ҳГӨв•ӘВ¬в•Әв–’в•ӘВ¬в”ҳГЁв•ӘВҝ</label>\n                <input\n                  type=\"number\"\n                  className=\"input\"\n                  value={form.order_index}\n                  onChange={e => setForm(f => ({ ...f, order_index: parseInt(e.target.value) || 0 }))}\n                />\n              </div>\n\n              {/* BG style */}\n              <div>\n                <label className=\"label\">в”ҳГӨв”ҳГӘв”ҳГҘ/в•ӘВ¬в•ӘВ»в•Әв–’в•ӘВј в•ӘВәв”ҳГӨв•ӘВ«в”ҳГӨв”ҳГјв”ҳГЁв•ӘвҢҗ (в”ҳГјв”ҳГЁ в•Әв”Өв•ӘВәв•Әв”Өв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»)</label>\n                <div className=\"grid grid-cols-2 gap-2 mt-2\">\n                  {BG_STYLES.map(bg => (\n                    <button\n                      key={bg.value}\n                      onClick={() => setForm(f => ({ ...f, bg_style: bg.value }))}\n                      className={`text-xs p-3 rounded-xl border-2 transition-all text-white/80 relative overflow-hidden ${\n                        form.bg_style === bg.value ? 'border-white font-bold' : 'border-white/10 hover:border-white/30'\n                      }`}\n                    >\n                      {bg.label}\n                    </button>\n                  ))}\n                </div>\n              </div>\n\n              {/* Video */}\n              <div>\n                <label className=\"label\">в”ҳГјв”ҳГЁв•ӘВ»в”ҳГЁв”ҳГӘ в•ӘВәв”ҳГӨв•ӘВ«в”ҳГӨв”ҳГјв”ҳГЁв•ӘвҢҗ (в•ӘВәв•ӘВ«в•ӘВ¬в”ҳГЁв•ӘВәв•Әв–’в”ҳГЁ)</label>\n                <div className=\"flex flex-col gap-3\">\n                  <input\n                    className=\"input\"\n                    value={form.video_url}\n                    onChange={e => setForm(f => ({ ...f, video_url: e.target.value }))}\n                    placeholder=\"в•Әв–’в•ӘВәв•ӘВҝв•Әв•– в”ҳГ в•ӘВҝв•ӘВәв•Әв”Өв•Әв–’ в”ҳГӨв”ҳГӨв”ҳГјв”ҳГЁв•ӘВ»в”ҳГЁв”ҳГӘ (MP4)\"\n                  />\n                  <div className=\"relative\">\n                    <input\n                      type=\"file\"\n                      accept=\"video/mp4,video/webm\"\n                      onChange={handleVideoUpload}\n                      disabled={uploading}\n                      className=\"block w-full text-sm text-white/50 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-bold file:bg-purple-500/20 file:text-purple-300 hover:file:bg-purple-500/30 transition-all cursor-pointer disabled:opacity-50\"\n                    />\n                    {uploading && (\n                      <div className=\"absolute right-4 top-2 text-xs text-cyan-400 animate-pulse font-bold\">\n                        в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•Әв–’в”ҳГјв•Әв•Ј...\n                      </div>\n                    )}\n                  </div>\n                  {form.video_url && (\n                    <button\n                      type=\"button\"\n                      onClick={() => setCropEditorUrl(form.video_url)}\n                      className=\"w-full py-2 rounded-xl text-sm font-bold flex items-center justify-center gap-2 transition-colors\"\n                      style={{ border: '1px solid rgba(139,92,246,0.3)', background: 'rgba(139,92,246,0.1)', color: '#c4b5fd' }}\n                    >\n                      <span>О“ВЈГ©вҲ©в••Г…</span>\n                      <span>в•Әв•ўв•ӘВҝв•Әв•– в•ӘВәв”ҳГӨв”ҳГ©в•Әв•Ў в”ҳГӘв•ӘВәв”ҳГӨв•ӘВ¬в”ҳГўв•ӘВҝв”ҳГЁв•Әв–’</span>\n                      {cropConfig && (\n                        <span className=\"text-xs px-2 py-0.5 rounded-full\" style={{ background: 'rgba(34,197,94,0.2)', color: '#4ade80' }}>\n                          в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•Әв•ўв•ӘВҝв•Әв•– О“ВЈГҙ\n                        </span>\n                      )}\n                    </button>\n                  )}\n                </div>\n              </div>\n\n              {/* Color */}\n              <div>\n                <label className=\"label\">в•ӘВәв”ҳГӨв”ҳГӨв”ҳГӘв”ҳГҘ</label>\n                <div className=\"flex flex-wrap gap-2 mt-2\">\n                  {COLORS.map(color => (\n                    <button\n                      key={color}\n                      onClick={() => setForm(f => ({ ...f, color }))}\n                      className=\"w-8 h-8 rounded-full border-2 transition-all\"\n                      style={{\n                        backgroundColor: color,\n                        borderColor:     form.color === color ? 'white' : 'transparent',\n                        transform:       form.color === color ? 'scale(1.15)' : 'scale(1)',\n                      }}\n                    />\n                  ))}\n                </div>\n              </div>\n\n              {/* Icon */}\n              <div>\n                <label className=\"label\">в•ӘВәв”ҳГӨв•ӘГәв”ҳГЁв”ҳГ©в”ҳГӘв”ҳГҘв•ӘвҢҗ</label>\n                <div className=\"flex flex-wrap gap-2 mt-2\">\n                  {ICONS.map(icon => (\n                    <button\n                      key={icon}\n                      onClick={() => setForm(f => ({ ...f, icon }))}\n                      className=\"w-10 h-10 rounded-xl text-xl flex items-center justify-center transition-all\"\n                      style={{\n                        background: form.icon === icon ? `${form.color}40` : 'var(--color-surface-3)',\n                        transform:  form.icon === icon ? 'scale(1.15)' : 'scale(1)',\n                      }}\n                    >\n                      {icon}\n                    </button>\n                  ))}\n                </div>\n              </div>\n\n              {/* Actions */}\n              <div className=\"flex gap-3 pt-2\">\n                <button onClick={save} disabled={saving} className=\"btn btn-primary flex-1\">\n                  {saving ? 'в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•ӘВЎв”ҳГјв•Әв••...' : editing ? 'в•ӘВЎв”ҳГјв•Әв••' : 'в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ'}\n                </button>\n                <button onClick={() => setModal(false)} className=\"btn btn-ghost\">в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ</button>\n              </div>\n            </motion.div>\n          </motion.div>\n        )}\n      </AnimatePresence>\n\n      {/* О“Г¶ГҮО“Г¶ГҮ Delete Confirm Modal О“Г¶ГҮО“Г¶ГҮ */}\n      <AnimatePresence>\n        {deleteId && (\n          <motion.div\n            initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}\n            className=\"fixed inset-0 z-50 flex items-center justify-center p-4\"\n            style={{ background: 'rgba(0,0,0,0.7)' }}\n          >\n            <motion.div\n              initial={{ scale: 0.9 }} animate={{ scale: 1 }} exit={{ scale: 0.9 }}\n              className=\"card-glass p-8 max-w-sm w-full text-center space-y-5\"\n            >\n              <div className=\"text-5xl\">вүЎЖ’Г№ГҰвҲ©в••Г…</div>\n              <h3 className=\"text-xl font-bold\" style={{ color: 'var(--color-text-primary)' }}>в•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ» в•ӘВәв”ҳГӨв•ӘВЎв•Әв–‘в”ҳГј</h3>\n              <p style={{ color: 'var(--color-text-secondary)' }}>\n                в•Әв”Ӯв”ҳГЁв•ӘВ¬в”ҳГ  в•ӘВЎв•Әв–‘в”ҳГј в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•Әв•ўв”ҳГӘв•Әв•Ј в”ҳГӘв•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в”ҳГјв•ӘВӘв•ӘВәв•ӘВ¬в”ҳГ§ в”ҳГӘв•ӘГәв•Әв”Ӯв•ӘВӘв”ҳГӨв•ӘВ¬в”ҳГ§ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в•ӘВ¬в•ӘВҝв•Әв•–в•ӘвҢҗ в•ӘВҝв”ҳГ§. в”ҳГ§в”ҳГӨ в•ӘГәв”ҳГҘв•ӘВ¬ в”ҳГ в•ӘВ¬в•ӘГәв”ҳГўв•ӘВ»в•ӘЖ’\n              </p>\n              <div className=\"flex gap-3\">\n                <button\n                  onClick={() => del(deleteId)}\n                  className=\"btn flex-1\"\n                  style={{ background: 'rgba(239,68,68,0.15)', color: '#ef4444', border: '1px solid rgba(239,68,68,0.3)' }}\n                >\n                  в”ҳГҘв•Әв•Јв”ҳГ в•ӘГ® в•ӘВәв•ӘВЎв•Әв–‘в”ҳГј\n                </button>\n                <button onClick={() => setDeleteId(null)} className=\"btn btn-ghost flex-1\">в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ</button>\n              </div>\n            </motion.div>\n          </motion.div>\n        )}\n      </AnimatePresence>\n\n      {/* О“Г¶ГҮО“Г¶ГҮ Crop Editor Modal О“Г¶ГҮО“Г¶ГҮ */}\n      <AnimatePresence>\n        {cropEditorUrl && (\n          <MediaCropEditor\n            mediaUrl={cropEditorUrl}\n            mediaType={\n              cropEditorUrl.includes('.mp4') || cropEditorUrl.includes('.webm')\n                ? 'video'\n                : 'image'\n            }\n            initialConfig={cropConfig ?? undefined}\n            availableSlots={['topic_bg']}\n            onSave={cfg => {\n              setCropConfig(cfg)\n              setCropEditorUrl(null)\n              toast.success('в•ӘВ¬в”ҳГ  в•ӘВЎв”ҳГјв•Әв•• в•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ©в•Әв•Ў')\n            }}\n            onClose={() => setCropEditorUrl(null)}\n          />\n        )}\n      </AnimatePresence>\n\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\components\\AppWrapper.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\components\\CookieBanner.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\components\\FightingParticles.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"The ref value 'stateRef.current' will likely have changed by the time this effect cleanup function runs. If this ref points to a node rendered by React, copy 'stateRef.current' to a variable inside the effect, and use that variable in the cleanup function.","line":131,"column":37,"nodeType":"Identifier","endLine":131,"endColumn":44}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useRef } from 'react'\r\n\r\ninterface Team { color: string; score?: number }\r\ninterface Particle {\r\n  x: number; y: number\r\n  vx: number; vy: number\r\n  color: string\r\n  teamIndex: number\r\n  radius: number\r\n}\r\n\r\ninterface FightingParticlesProps {\r\n  teams: Team[]\r\n  mode?: 'setup' | 'game'\r\n}\r\n\r\nexport default function FightingParticles({ teams, mode = 'game' }: FightingParticlesProps) {\r\n  const canvasRef = useRef<HTMLCanvasElement>(null)\r\n  const stateRef = useRef<{ particles: Particle[]; animId: number }>({ particles: [], animId: 0 })\r\n\r\n  useEffect(() => {\r\n    const canvas = canvasRef.current\r\n    if (!canvas) return\r\n    const ctx = canvas.getContext('2d')\r\n    if (!ctx) return\r\n\r\n    const resize = () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight }\r\n    window.addEventListener('resize', resize)\r\n    resize()\r\n\r\n    // Initialise particles\r\n    const COUNT_PER_TEAM = mode === 'setup' ? 20 : 30\r\n    const particles: Particle[] = []\r\n    teams.forEach((team, ti) => {\r\n      for (let k = 0; k < COUNT_PER_TEAM; k++) {\r\n        const angle = Math.random() * Math.PI * 2\r\n        const speed = 1.5 + Math.random() * 2\r\n        particles.push({\r\n          x: Math.random() * canvas.width,\r\n          y: Math.random() * canvas.height,\r\n          vx: Math.cos(angle) * speed,\r\n          vy: Math.sin(angle) * speed,\r\n          color: team.color,\r\n          teamIndex: ti,\r\n          radius: 3 + Math.random() * 4,\r\n        })\r\n      }\r\n    })\r\n    stateRef.current.particles = particles\r\n\r\n\r\n\r\n    const draw = () => {\r\n      ctx.fillStyle = 'rgba(5,5,5,0.18)'\r\n      ctx.fillRect(0, 0, canvas.width, canvas.height)\r\n\r\n      const ps = stateRef.current.particles\r\n\r\n      for (let i = 0; i < ps.length; i++) {\r\n        const p = ps[i]\r\n\r\n        // Bounce off walls\r\n        if (p.x < p.radius)                 { p.x = p.radius;                 p.vx *= -1 }\r\n        if (p.x > canvas.width - p.radius)  { p.x = canvas.width - p.radius;  p.vx *= -1 }\r\n        if (p.y < p.radius)                 { p.y = p.radius;                 p.vy *= -1 }\r\n        if (p.y > canvas.height - p.radius) { p.y = canvas.height - p.radius; p.vy *= -1 }\r\n\r\n        for (let j = i + 1; j < ps.length; j++) {\r\n          const q = ps[j]\r\n          const dx = q.x - p.x\r\n          const dy = q.y - p.y\r\n          const distSq = dx * dx + dy * dy\r\n          const dist = Math.sqrt(distSq) || 0.01\r\n\r\n          // Very simple collision & bounce\r\n          if (dist < 40) { // Collision or near-miss\r\n            const nx = dx / dist\r\n            const ny = dy / dist\r\n            \r\n            // Simple repulsion for all particles to bounce away from each other\r\n            const force = 5 / dist\r\n            p.vx -= nx * force\r\n            p.vy -= ny * force\r\n            q.vx += nx * force\r\n            q.vy += ny * force\r\n            \r\n            if (p.teamIndex !== q.teamIndex && dist < 20) {\r\n              // Draw a tiny flash on impact if they are very close and enemies\r\n               ctx.beginPath()\r\n               ctx.arc(p.x + dx/2, p.y + dy/2, 8, 0, Math.PI * 2)\r\n               ctx.fillStyle = 'rgba(255,255,255,0.8)'\r\n               ctx.fill()\r\n            }\r\n          }\r\n        }\r\n\r\n        // Apply friction to prevent them from flying too fast indefinitely\r\n        p.vx *= 0.99\r\n        p.vy *= 0.99\r\n\r\n        // Keep them moving if they slow down too much\r\n        const spd = Math.sqrt(p.vx * p.vx + p.vy * p.vy)\r\n        if (spd < 1.5) {\r\n          p.vx += (Math.random() - 0.5) * 0.5\r\n          p.vy += (Math.random() - 0.5) * 0.5\r\n        } else if (spd > 6) {\r\n          // Cap maximum speed\r\n          p.vx = (p.vx / spd) * 6\r\n          p.vy = (p.vy / spd) * 6\r\n        }\r\n\r\n        p.x += p.vx\r\n        p.y += p.vy\r\n\r\n        // Draw\r\n        ctx.beginPath()\r\n        ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2)\r\n        ctx.fillStyle = p.color\r\n        ctx.fill()\r\n      }\r\n\r\n      stateRef.current.animId = requestAnimationFrame(draw)\r\n    }\r\n\r\n    draw()\r\n\r\n    return () => {\r\n      window.removeEventListener('resize', resize)\r\n      cancelAnimationFrame(stateRef.current.animId)\r\n    }\r\n  }, [teams, mode])\r\n\r\n  return (\r\n    <canvas\r\n      ref={canvasRef}\r\n      className=\"absolute inset-0 w-full h-full pointer-events-none z-0 mix-blend-screen opacity-70\"\r\n    />\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\components\\Fireworks.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":18,"column":22,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":18,"endColumn":25,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[542,545],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[542,545],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":19,"column":20,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":19,"endColumn":23,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[573,576],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[573,576],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useRef } from 'react'\r\n\r\nexport default function Fireworks({ colors }: { colors: string[] }) {\r\n  const canvasRef = useRef<HTMLCanvasElement>(null)\r\n\r\n  useEffect(() => {\r\n    const canvas = canvasRef.current\r\n    if (!canvas || colors.length === 0) return\r\n    const ctx = canvas.getContext('2d')\r\n    if (!ctx) return\r\n\r\n    const resize = () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight }\r\n    window.addEventListener('resize', resize)\r\n    resize()\r\n\r\n    const particles: any[] = []\r\n    const rockets: any[] = []\r\n    let animId = 0\r\n\r\n    const createExplosion = (x: number, y: number, color: string) => {\r\n      const pCount = 15 + Math.random() * 15\r\n      for (let i = 0; i < pCount; i++) {\r\n        const angle = Math.random() * Math.PI * 2\r\n        const speed = Math.random() * 3 + 0.5\r\n        particles.push({\r\n          x, y,\r\n          vx: Math.cos(angle) * speed,\r\n          vy: Math.sin(angle) * speed,\r\n          color,\r\n          alpha: 1,\r\n          decay: Math.random() * 0.01 + 0.005\r\n        })\r\n      }\r\n    }\r\n\r\n    const launchRocket = () => {\r\n      const x = canvas.width * 0.2 + Math.random() * (canvas.width * 0.6) // Launch from middle 60% of width\r\n      const y = canvas.height\r\n      const color = colors[Math.floor(Math.random() * colors.length)]\r\n      const vy = -(Math.random() * 3 + 5) // Shoot up slowly\r\n      const vx = (Math.random() - 0.5) * 2\r\n      rockets.push({ x, y, vx, vy, color, alpha: 1 })\r\n    }\r\n\r\n    // Auto trigger fireworks rockets less frequently\r\n    const triggerInterval = setInterval(() => {\r\n      launchRocket()\r\n    }, 2500)\r\n\r\n    launchRocket()\r\n\r\n    const draw = () => {\r\n      ctx.globalCompositeOperation = 'destination-out'\r\n      ctx.fillStyle = 'rgba(0,0,0,0.1)'\r\n      ctx.fillRect(0, 0, canvas.width, canvas.height)\r\n      ctx.globalCompositeOperation = 'lighter'\r\n\r\n      // Draw and update rockets\r\n      for (let i = rockets.length - 1; i >= 0; i--) {\r\n        const r = rockets[i]\r\n        r.x += r.vx\r\n        r.y += r.vy\r\n        r.vy += 0.04 // gravity\r\n        \r\n        ctx.beginPath()\r\n        ctx.arc(r.x, r.y, 2, 0, Math.PI * 2)\r\n        ctx.fillStyle = r.color\r\n        ctx.shadowBlur = 8\r\n        ctx.shadowColor = r.color\r\n        ctx.fill()\r\n\r\n        // Explode at peak\r\n        if (r.vy >= -0.5) {\r\n          createExplosion(r.x, r.y, r.color)\r\n          rockets.splice(i, 1)\r\n        }\r\n      }\r\n\r\n      // Draw and update explosion particles\r\n      for (let i = particles.length - 1; i >= 0; i--) {\r\n        const p = particles[i]\r\n        p.x += p.vx\r\n        p.y += p.vy\r\n        p.vy += 0.03 // light gravity\r\n        p.alpha -= p.decay\r\n\r\n        if (p.alpha <= 0) {\r\n          particles.splice(i, 1)\r\n          continue\r\n        }\r\n\r\n        ctx.beginPath()\r\n        ctx.arc(p.x, p.y, 1.2, 0, Math.PI * 2)\r\n        ctx.fillStyle = p.color\r\n        ctx.globalAlpha = p.alpha\r\n        ctx.shadowBlur = 4\r\n        ctx.shadowColor = p.color\r\n        ctx.fill()\r\n      }\r\n      ctx.globalAlpha = 1\r\n      ctx.shadowBlur = 0\r\n      animId = requestAnimationFrame(draw)\r\n    }\r\n    draw()\r\n\r\n    return () => {\r\n      window.removeEventListener('resize', resize)\r\n      clearInterval(triggerInterval)\r\n      cancelAnimationFrame(animId)\r\n    }\r\n  }, [colors])\r\n\r\n  return (\r\n    <canvas\r\n      ref={canvasRef}\r\n      className=\"absolute inset-0 w-full h-full pointer-events-none z-10\"\r\n    />\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\components\\GameBoard.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'gameEngine' is defined but never used.","line":9,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":20,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"gameEngine"},"fix":{"range":[341,388],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'TEAM_PALETTE' is defined but never used.","line":11,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":11,"endColumn":30,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"TEAM_PALETTE"},"fix":{"range":[437,455],"text":""},"desc":"Remove u