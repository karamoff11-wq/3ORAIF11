”ҳГҘ в•Әв•Ўв”ҳГӘв•ӘВ¬ в”ҳГӨв”ҳГЁв”ҳГҘв•ӘВәв•Әв”Ӯв•ӘВҝ в•ӘВ¬в•Әв•Ўв”ҳГ в”ҳГЁв”ҳГ  \"Pure Void&rdquo;.\n              "},"desc":"Replace with `&rdquo;`."}]},{"ruleId":"react/no-unescaped-entities","severity":2,"message":"`\"` can be escaped with `&quot;`, `&ldquo;`, `&#34;`, `&rdquo;`.","line":288,"column":86,"nodeType":"JSXText","messageId":"unescapedEntityAlts","suggestions":[{"messageId":"replaceWithAlt","data":{"alt":"&quot;"},"fix":{"range":[15119,15120],"text":"&quot;"},"desc":"Replace with `&quot;`."},{"messageId":"replaceWithAlt","data":{"alt":"&ldquo;"},"fix":{"range":[15119,15120],"text":"&ldquo;"},"desc":"Replace with `&ldquo;`."},{"messageId":"replaceWithAlt","data":{"alt":"&#34;"},"fix":{"range":[15119,15120],"text":"&#34;"},"desc":"Replace with `&#34;`."},{"messageId":"replaceWithAlt","data":{"alt":"&rdquo;"},"fix":{"range":[15119,15120],"text":"&rdquo;"},"desc":"Replace with `&rdquo;`."}]},{"ruleId":"react/no-unescaped-entities","severity":2,"message":"`\"` can be escaped with `&quot;`, `&ldquo;`, `&#34;`, `&rdquo;`.","line":288,"column":95,"nodeType":"JSXText","messageId":"unescapedEntityAlts","suggestions":[{"messageId":"replaceWithAlt","data":{"alt":"&quot;"},"fix":{"range":[15128,15129],"text":"&quot;"},"desc":"Replace with `&quot;`."},{"messageId":"replaceWithAlt","data":{"alt":"&ldquo;"},"fix":{"range":[15128,15129],"text":"&ldquo;"},"desc":"Replace with `&ldquo;`."},{"messageId":"replaceWithAlt","data":{"alt":"&#34;"},"fix":{"range":[15128,15129],"text":"&#34;"},"desc":"Replace with `&#34;`."},{"messageId":"replaceWithAlt","data":{"alt":"&rdquo;"},"fix":{"range":[15128,15129],"text":"&rdquo;"},"desc":"Replace with `&rdquo;`."}]}],"suppressedMessages":[],"errorCount":5,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nexport const dynamic = 'force-dynamic'\n\nimport { useState, useEffect } from 'react'\nimport Link from 'next/link'\nimport { motion, AnimatePresence } from 'framer-motion'\n\nimport { useFeedbackStore } from '@/store/feedbackStore'\n\nconst getYouTubeId = (url: string) => {\n  const regExp = /^.*(youtu.be\\/|v\\/|u\\/\\w\\/|embed\\/|watch\\?v=|\\&v=)([^#\\&\\?]*).*/;\n  const match = url?.match(regExp);\n  return (match && match[2].length === 11) ? match[2] : null;\n};\n\nexport default function AdminFeedbackPage() {\n  const { \n    comments, toggleVisibility, deleteComment, \n    videoUrl, setVideoUrl, \n    logoUrl, setLogoUrl,\n    accentColor, setAccentColor, roadmapNodes, setRoadmapNodes \n  } = useFeedbackStore()\n  const [urlInput, setUrlInput] = useState(videoUrl)\n  const [logoInput, setLogoInput] = useState(logoUrl)\n\n  // Sync inputs with store when it hydrates\n  useEffect(() => {\n    setUrlInput(videoUrl)\n    setLogoInput(logoUrl)\n  }, [videoUrl, logoUrl])\n\n  return (\n    <div className=\"min-h-screen bg-[#07071A] text-white p-8 font-sans\" style={{ direction: 'rtl' }}>\n      <div className=\"max-w-4xl mx-auto\">\n        <header className=\"flex flex-col md:flex-row items-start md:items-center justify-between gap-6 mb-12\">\n          <div>\n            <h1 className=\"text-4xl font-black mb-3 tracking-tight\">в•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ§в”ҳГӘв”ҳГЁв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВҝв•Әв•Ўв•Әв–’в”ҳГЁв•ӘвҢҗ</h1>\n            <p className=\"text-white/40 text-sm\">в•ӘВ¬в•ӘВЎв”ҳГўв”ҳГ  в”ҳГјв”ҳГЁ в•ӘВәв”ҳГӨв•Әв”Өв•Әв•Јв•ӘВәв•Әв–’в•ӘГ® в•ӘВәв”ҳГӨв”ҳГјв”ҳГЁв•ӘВ»в”ҳГЁв”ҳГӘв•ӘГ® в”ҳГӘв•ӘГів•Әв–’в•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв”ҳГӨв•ӘВәв•Әв•Јв•ӘВҝв”ҳГЁв”ҳГҘ в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВәв”ҳГӨв”ҳГ в”ҳГҘв•Әв•Ўв•ӘвҢҗ</p>\n          </div>\n          <Link href=\"/admin\" className=\"px-6 py-3 rounded-2xl bg-white/5 border border-white/10 text-sm font-bold hover:bg-white/10 transition-all flex items-center gap-2\">\n            <span>в•ӘВәв”ҳГӨв•Әв•Јв”ҳГӘв•ӘВ»в•ӘвҢҗ в”ҳГӨв”ҳГӨв”ҳГӘв•ӘВЎв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГўв”ҳГ </span>\n            <span>вүЎЖ’Г…ГЎ</span>\n          </Link>\n        </header>\n\n        {/* О“Г¶ГҮО“Г¶ГҮ Logo Management О“Г¶ГҮО“Г¶ГҮ */}\n        <section className=\"mb-12 p-8 rounded-[2rem] bg-white/[0.02] border border-white/10 backdrop-blur-xl\">\n          <div className=\"flex items-center gap-3 mb-6\">\n            <span className=\"text-2xl\">О“ВЈВҝ</span>\n            <h2 className=\"text-xl font-bold\">в•Әв”Өв•Әв•Јв•ӘВәв•Әв–’ в•ӘВәв”ҳГӨв”ҳГ в”ҳГҘв•Әв•Ўв•ӘвҢҗ (Logo)</h2>\n          </div>\n          \n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n            <div className=\"space-y-4\">\n              <p className=\"text-xs text-white/40 leading-relaxed\">в•ӘГәв•ӘВ»в•ӘВ«в”ҳГӨ в•Әв–’в•ӘВәв•ӘВҝв•Әв•– в•Әв•Ўв”ҳГӘв•Әв–’в•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв”Өв•Әв•Јв•ӘВәв•Әв–’ (PNG, SVG, GIF). в•ӘГ‘в•Әв–‘в•ӘВә в•ӘВ¬в•Әв–’в”ҳГўв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВЎв”ҳГ©в”ҳГӨ в”ҳГјв•ӘВәв•Әв–’в•Әв•‘в•ӘВәв”ҳГҜв•ӘГ® в•Әв”Ӯв”ҳГЁв•ӘВ¬в”ҳГ  в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в•ӘВәв”ҳГ  в•ӘВәв”ҳГӨв•Әв”Өв•Әв•Јв•ӘВәв•Әв–’ в•ӘВәв”ҳГӨв•ӘВәв”ҳГјв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ўв”ҳГЁ в•ӘВәв”ҳГӨв•Әв–‘в”ҳГўв”ҳГЁ в”ҳГӨв”ҳГӨв”ҳГ в”ҳГҘв•Әв•Ўв•ӘвҢҗ.</p>\n              <div className=\"flex gap-2\">\n                <input \n                  type=\"text\" \n                  value={logoInput}\n                  onChange={(e) => setLogoInput(e.target.value)}\n                  placeholder=\"https://example.com/logo.svg\"\n                  className=\"flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-500/50 transition-all\"\n                />\n                <button \n                  onClick={() => setLogoUrl(logoInput)}\n                  className=\"px-6 py-3 rounded-xl bg-emerald-600 text-xs font-black hover:bg-emerald-500 transition-all active:scale-95\"\n                >\n                  в•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪ в•ӘВәв”ҳГӨв•Әв”Өв•Әв•Јв•ӘВәв•Әв–’\n                </button>\n              </div>\n            </div>\n            \n            <div className=\"flex items-center gap-8 p-6 rounded-2xl bg-black/40 border border-white/5\">\n              <div className=\"text-center\">\n                <div className=\"w-16 h-16 rounded-xl bg-white/5 border border-white/10 mb-2 flex items-center justify-center overflow-hidden\">\n                  {logoUrl ? <img src={logoUrl} className=\"w-full h-full object-contain\" /> : <span className=\"text-white/20 text-xs italic\">в”ҳГӨв•ӘВә в”ҳГЁв”ҳГӘв•ӘВјв•ӘВ»</span>}\n                </div>\n                <span className=\"text-[10px] text-white/40 uppercase font-black\">в•ӘВәв”ҳГӨв•Әв”Өв•Әв•Јв•ӘВәв•Әв–’ в•ӘВәв”ҳГӨв•ӘВЎв•ӘВәв”ҳГӨв”ҳГЁ</span>\n              </div>\n              <div className=\"text-center\">\n                <div className=\"w-16 h-16 rounded-xl flex items-center justify-center text-xl font-black text-white shadow-[0_0_20px_rgba(139,92,246,0.3)] mb-2\"\n                  style={{ background: `linear-gradient(135deg, ${accentColor}, #3B82F6)` }}>A</div>\n                <span className=\"text-[10px] text-white/40 uppercase font-black\">в•ӘВәв”ҳГӨв•ӘВәв•ӘВЎв•ӘВ¬в”ҳГЁв•ӘВәв•Әв•–в”ҳГЁ</span>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        {/* О“Г¶ГҮО“Г¶ГҮ Accent Color Management О“Г¶ГҮО“Г¶ГҮ */}\n        <section className=\"mb-12 p-8 rounded-[2rem] bg-white/[0.02] border border-white/10 backdrop-blur-xl\">\n          <div className=\"flex items-center gap-3 mb-6\">\n            <span className=\"text-2xl\">вүЎЖ’Г„Вҝ</span>\n            <h2 className=\"text-xl font-bold\">в•ӘВәв”ҳГӨв”ҳГӨв”ҳГӘв”ҳГҘ в•ӘВәв”ҳГӨв•ӘГәв•Әв”Ӯв•ӘВәв•Әв”Ӯв”ҳГЁ (Global Accent)</h2>\n          </div>\n          \n          <div className=\"flex flex-wrap gap-4\">\n            {[\n              { name: 'в•ӘВҝв”ҳГҘв”ҳГјв•Әв”Ӯв•ӘВјв”ҳГЁ', hex: '#8B5CF6' },\n              { name: 'в•Әв–“в”ҳГ в•Әв–’в•ӘВ»в”ҳГЁ', hex: '#10B981' },\n              { name: 'в•Әв–‘в”ҳГ§в•ӘВҝв”ҳГЁ', hex: '#F59E0B' },\n              { name: 'в”ҳГӘв•Әв–’в•ӘВ»в”ҳГЁ', hex: '#F43F5E' },\n              { name: 'в•Әв”Ӯв”ҳГ в•ӘВәв”ҳГӘв”ҳГЁ', hex: '#0EA5E9' }\n            ].map((c) => (\n              <button\n                key={c.hex}\n                onClick={() => setAccentColor(c.hex)}\n                className={`flex items-center gap-3 px-5 py-3 rounded-2xl border transition-all hover:scale-105 active:scale-95 ${\n                  accentColor === c.hex ? 'bg-white/10 border-white/40' : 'bg-white/2 border-white/5'\n                }`}\n              >\n                <div \n                  className=\"w-5 h-5 rounded-full shadow-lg\" \n                  style={{ background: c.hex, boxShadow: `0 0 15px ${c.hex}60` }}\n                />\n                <span className={`text-xs font-bold ${accentColor === c.hex ? 'text-white' : 'text-white/40'}`}>{c.name}</span>\n                {accentColor === c.hex && <span className=\"text-[10px]\">О“ВЈГ </span>}\n              </button>\n            ))}\n          </div>\n          <p className=\"mt-6 text-[10px] text-white/30 italic\">в•Әв”Ӯв”ҳГЁв•ӘВ¬в”ҳГ  в•ӘВ¬в•Әв•–в•ӘВҝв”ҳГЁв”ҳГ© в”ҳГ§в•Әв–‘в•ӘВә в•ӘВәв”ҳГӨв”ҳГӨв”ҳГӘв”ҳГҘ в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВ»в•Әв–’в•ӘВјв•ӘВәв•ӘВ¬в•ӘГ® в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•ўв•ӘВәв•ӘГӯв•ӘВәв•ӘВ¬в•ӘГ® в”ҳГӘв•ӘВәв”ҳГӨв•ӘГәв•Әв–“в•Әв–’в•ӘВәв•Әв–’ в”ҳГјв”ҳГЁ в•ӘВәв”ҳГӨв”ҳГ в”ҳГҘв•Әв•Ўв•ӘвҢҗ в•ӘВҝв•Әв”Өв”ҳГўв”ҳГӨ в•ӘВ¬в”ҳГӨв”ҳГ©в•ӘВәв•ӘВӘв”ҳГЁ.</p>\n        </section>\n\n        {/* О“Г¶ГҮО“Г¶ГҮ Video Management О“Г¶ГҮО“Г¶ГҮ */}\n        <section className=\"mb-16 p-8 rounded-[2rem] bg-white/[0.02] border border-white/10 backdrop-blur-xl\">\n          <div className=\"flex items-center gap-3 mb-6\">\n            <span className=\"text-2xl\">вүЎЖ’Г„Вј</span>\n            <h2 className=\"text-xl font-bold\">в”ҳГјв”ҳГЁв•ӘВ»в”ҳГЁв”ҳГӘ в•ӘВәв”ҳГӨв•Әв”Өв•Әв–’в•ӘВЎ (How to Play)</h2>\n          </div>\n          \n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n            <div className=\"space-y-4\">\n              <p className=\"text-xs text-white/40 leading-relaxed\">в•ӘГәв•ӘВ»в•ӘВ«в”ҳГӨ в•Әв–’в•ӘВәв•ӘВҝв•Әв•– в”ҳГјв”ҳГЁв•ӘВ»в”ҳГЁв”ҳГӘ в•ӘВәв”ҳГӨв•Әв”Өв•Әв–’в•ӘВЎ. в”ҳГЁв”ҳГ в”ҳГўв”ҳГҘв”ҳГў в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в•ӘВәв”ҳГ  в•Әв–’в”ҳГӘв•ӘВәв•ӘВҝв•Әв•– MP4 в”ҳГ в•ӘВҝв•ӘВәв•Әв”Өв•Әв–’в•ӘвҢҗ в•ӘГәв”ҳГӘ в•Әв–’в”ҳГӘв•ӘВәв•ӘВҝв•Әв•– YouTube.</p>\n              <div className=\"p-3 rounded-xl bg-blue-500/10 border border-blue-500/20 text-[10px] text-blue-300 leading-tight\">\n                О“ГӨв•ЈвҲ©в••Г… в”ҳГ в”ҳГӨв•ӘВәв•ӘВЎв•Әв••в•ӘвҢҗ: в”ҳГҘв•ӘВ»в•Әв•Јв”ҳГ  в•ӘВәв”ҳГӨв•ӘГів”ҳГҘ в•Әв–’в”ҳГӘв•ӘВәв•ӘВҝв•Әв•– YouTube! в•Әв”Ӯв”ҳГЁв•ӘВ¬в”ҳГ  в•Әв•Јв•Әв–’в•Әв•ў в•ӘВәв”ҳГӨв”ҳГјв”ҳГЁв•ӘВ»в”ҳГЁв”ҳГӘ в”ҳГјв”ҳГЁ в•ӘВәв”ҳГӨв•ӘВ«в”ҳГӨв”ҳГјв”ҳГЁв•ӘвҢҗ в•ӘВҝв•Әв”Өв”ҳГўв”ҳГӨ в•ӘВ¬в”ҳГӨв”ҳГ©в•ӘВәв•ӘВӘв”ҳГЁ в”ҳГӘв•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в•Әв•Ўв”ҳГӘв•ӘВ¬ в”ҳГӨв”ҳГЁв”ҳГҘв•ӘВәв•Әв”Ӯв•ӘВҝ в•ӘВ¬в•Әв•Ўв”ҳГ в”ҳГЁв”ҳГ  \"Pure Void\".\n              </div>\n              <div className=\"flex gap-2\">\n                <input \n                  type=\"text\" \n                  value={urlInput}\n                  onChange={(e) => setUrlInput(e.target.value)}\n                  placeholder=\"https://youtube.com/watch?v=...\"\n                  className=\"flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-500/50 transition-all\"\n                />\n                <button \n                  onClick={() => setVideoUrl(urlInput)}\n                  className=\"px-6 py-3 rounded-xl bg-purple-600 text-xs font-black hover:bg-purple-500 transition-all active:scale-95\"\n                >\n                  в•ӘВЎв”ҳГјв•Әв•• в•ӘВәв”ҳГӨв•Әв–’в•ӘВәв•ӘВҝв•Әв•–\n                </button>\n              </div>\n              {urlInput !== videoUrl && (\n                <p className=\"text-[10px] text-amber-400 font-bold animate-pulse\">О“ГңГЎвҲ©в••Г… в”ҳГЁв”ҳГӘв•ӘВјв•ӘВ» в•ӘВ¬в•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’в•ӘВәв•ӘВ¬ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘВЎв”ҳГјв”ҳГӘв•Әв••в•ӘвҢҗ</p>\n              )}\n            </div>\n            \n            <div className=\"relative aspect-video rounded-2xl overflow-hidden border border-white/10 bg-black\">\n              {(() => {\n                const ytId = getYouTubeId(videoUrl)\n                if (ytId) {\n                  return (\n                    <iframe \n                      key={ytId}\n                      src={`https://www.youtube.com/embed/${ytId}?autoplay=1&mute=1&controls=0&loop=1&playlist=${ytId}&modestbranding=1&rel=0`}\n                      className=\"w-[200%] h-[200%] absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-60 grayscale pointer-events-none\"\n                    />\n                  )\n                }\n                return (\n                  <video key={videoUrl} autoPlay loop muted className=\"w-full h-full object-cover opacity-60\">\n                    <source src={videoUrl} type=\"video/mp4\" />\n                  </video>\n                )\n              })()}\n              <div className=\"absolute inset-0 flex items-center justify-center pointer-events-none\">\n                <span className=\"text-[10px] uppercase tracking-widest font-black bg-black/60 px-3 py-1 rounded-full border border-white/10 z-10\">в”ҳГ в•Әв•Јв•ӘВәв”ҳГЁв”ҳГҘв•ӘвҢҗ в”ҳГ в•ӘВҝв•ӘВәв•Әв”Өв•Әв–’в•ӘвҢҗ</span>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        {/* О“Г¶ГҮО“Г¶ГҮ ROADMAP MANAGEMENT О“Г¶ГҮО“Г¶ГҮ */}\n        <section className=\"bg-white/5 border border-white/10 rounded-3xl p-8 backdrop-blur-xl mb-12\">\n          <div className=\"flex items-center justify-between mb-8\">\n            <div>\n              <h2 className=\"text-2xl font-black text-white mb-2\">вүЎЖ’Г№в•‘вҲ©в••Г… в•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в•ӘвҢҗ в•ӘВ«в•ӘВәв•Әв–’в•Әв•–в•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•–в•Әв–’в”ҳГЁв”ҳГ©</h2>\n              <p className=\"text-white/40 text-sm\">в•ӘВЎв•ӘВ»в•ӘВ» в”ҳГ в•Әв•Јв•ӘВәв”ҳГӨв”ҳГ  в•ӘВәв”ҳГӨв”ҳГ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в”ҳГӘв”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГ©в•ӘВҝв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГ в”ҳГҘв•Әв•Ўв•ӘвҢҗ</p>\n            </div>\n            <button \n        