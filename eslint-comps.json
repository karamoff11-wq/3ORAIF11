п»ҝ[{"filePath":"C:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\app\\admin\\appearance\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":212,"column":65,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":212,"endColumn":68,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[9724,9727],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[9724,9727],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'supabase'. Either include it or remove the dependency array.","line":99,"column":6,"nodeType":"ArrayExpression","endLine":99,"endColumn":8,"suggestions":[{"desc":"Update the dependencies array to be: [supabase]","fix":{"range":[4051,4053],"text":"[supabase]"}}],"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useEffect, useState } from 'react'\nimport { motion } from 'framer-motion'\nimport { createClient } from '@/lib/supabaseClient'\nimport toast from 'react-hot-toast'\nimport {\n  APPEARANCE_DEFAULTS,\n  type AppearanceSettings,\n  getAppSettings,\n  saveAppSettings,\n} from '@/lib/appSettings'\n\nconst FONTS = ['Cairo', 'Tajawal', 'Inter'] as const\n\nconst PRESET_PALETTES = [\n  { label: 'Void Purple (Default)', primary: '#7c3aed', accent: '#f59e0b', bg: '#04040f' },\n  { label: 'Ocean Blue',            primary: '#2563eb', accent: '#06b6d4', bg: '#040f1a' },\n  { label: 'Rose Gold',             primary: '#e11d48', accent: '#f97316', bg: '#0f0406' },\n  { label: 'Emerald Night',         primary: '#059669', accent: '#8b5cf6', bg: '#02100a' },\n  { label: 'Cyber Yellow',          primary: '#ca8a04', accent: '#3b82f6', bg: '#0a0900' },\n]\n\nfunction ColorSwatch({ label, value, onChange }: { label: string; value: string; onChange: (v: string) => void }) {\n  return (\n    <div className=\"card-glass flex items-center gap-4 p-4\">\n      <div className=\"relative\">\n        <input\n          type=\"color\"\n          value={value}\n          onChange={e => onChange(e.target.value)}\n          className=\"w-12 h-12 rounded-xl border border-white/10 cursor-pointer bg-transparent p-0.5\"\n        />\n      </div>\n      <div className=\"flex-1\">\n        <p className=\"text-sm font-bold\" style={{ color: 'var(--color-text-primary)' }}>{label}</p>\n        <p className=\"text-xs font-mono mt-0.5\" style={{ color: 'var(--color-text-muted)' }}>{value}</p>\n      </div>\n      <div className=\"w-8 h-8 rounded-full border border-white/10\" style={{ backgroundColor: value }} />\n    </div>\n  )\n}\n\nfunction Toggle({ label, desc, checked, onChange }: { label: string; desc?: string; checked: boolean; onChange: (v: boolean) => void }) {\n  return (\n    <div className=\"flex items-center justify-between gap-4 py-3 border-b\" style={{ borderColor: 'var(--color-border)' }}>\n      <div>\n        <p className=\"text-sm font-bold\" style={{ color: 'var(--color-text-primary)' }}>{label}</p>\n        {desc && <p className=\"text-xs mt-0.5\" style={{ color: 'var(--color-text-muted)' }}>{desc}</p>}\n      </div>\n      <button\n        onClick={() => onChange(!checked)}\n        className={`relative w-11 h-6 rounded-full transition-colors duration-200 focus:outline-none shrink-0 ${checked ? 'bg-purple-600' : 'bg-white/10'}`}\n      >\n        <span className={`absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-white shadow transition-transform duration-200 ${checked ? 'translate-x-5' : 'translate-x-0'}`} />\n      </button>\n    </div>\n  )\n}\n\nfunction ThemeSelector({ value, onChange }: { value: 'light' | 'dark' | 'system'; onChange: (v: 'light' | 'dark' | 'system') => void }) {\n  const options = [\n    { value: 'light',  label: 'в”ҳГҘв”ҳГ§в•ӘВәв•Әв–’в”ҳГЁ (Light)',  icon: 'О“ГҝГҮвҲ©в••Г…' },\n    { value: 'dark',   label: 'в”ҳГӨв”ҳГЁв”ҳГӨв”ҳГЁ (Dark)',   icon: 'вүЎЖ’Г®Г–' },\n    { value: 'system', label: 'в•ӘВ¬в”ҳГӨв”ҳГ©в•ӘВәв•ӘВӘв”ҳГЁ (System)', icon: 'вүЎЖ’Г»Г‘вҲ©в••Г…' },\n  ] as const\n\n  return (\n    <div className=\"flex gap-2\">\n      {options.map(opt => (\n        <button\n          key={opt.value}\n          onClick={() => onChange(opt.value)}\n          className={`flex-1 flex flex-col items-center gap-2 p-3 rounded-2xl border transition-all ${\n            value === opt.value\n              ? 'bg-purple-600/20 border-purple-500/50 text-purple-400'\n              : 'bg-white/5 border-white/10 text-white/40 hover:bg-white/10'\n          }`}\n        >\n          <span className=\"text-xl\">{opt.icon}</span>\n          <span className=\"text-[10px] font-black uppercase tracking-wider\">{opt.label}</span>\n        </button>\n      ))}\n    </div>\n  )\n}\n\nexport default function AdminAppearancePage() {\n  const supabase = createClient()\n  const [settings, setSettings] = useState<AppearanceSettings>(APPEARANCE_DEFAULTS)\n  const [loading, setLoading] = useState(true)\n  const [saving, setSaving] = useState(false)\n\n  useEffect(() => {\n    getAppSettings('appearance', APPEARANCE_DEFAULTS, supabase).then(s => {\n      setSettings(s)\n      setLoading(false)\n    })\n  }, []) // eslint-disable-line react-hooks/exhaustive-deps\n\n  function set<K extends keyof AppearanceSettings>(key: K, value: AppearanceSettings[K]) {\n    setSettings(s => ({ ...s, [key]: value }))\n  }\n\n  async function save() {\n    setSaving(true)\n    const { error } = await saveAppSettings('appearance', settings, supabase)\n    if (error) toast.error('в•ӘВ«в•Әв•–в•ӘГә в”ҳГјв”ҳГЁ в•ӘВәв”ҳГӨв•ӘВЎв”ҳГјв•Әв••: ' + error.message)\n    else toast.success('в•ӘВ¬в”ҳГ  в•ӘВЎв”ҳГјв•Әв•• в•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•Әв••в”ҳГ§в•Әв–’ О“ВЈГҙ О“ГҮГ¶ в•Әв”Ӯв•ӘВ¬в”ҳГ…в•Әв•–в•ӘВҝв”ҳГ© в•Әв•Јв”ҳГҘв•ӘВ» в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГјв•ӘВЎв•ӘвҢҗ')\n    setSaving(false)\n  }\n\n  function applyPreset(p: typeof PRESET_PALETTES[0]) {\n    setSettings(s => ({ ...s, primary_color: p.primary, accent_color: p.accent, bg_color: p.bg }))\n  }\n\n  if (loading) return (\n    <div className=\"p-8 space-y-4\">\n      {Array(5).fill(0).map((_, i) => <div key={i} className=\"h-16 card-glass animate-shimmer rounded-2xl\" />)}\n    </div>\n  )\n\n  return (\n    <div className=\"p-8 max-w-3xl space-y-10\">\n\n      {/* Header */}\n      <div>\n        <h1 className=\"text-3xl font-black gradient-text-primary\">в•ӘВәв”ҳГӨв”ҳГ в•Әв••в”ҳГ§в•Әв–’ в”ҳГӘв•ӘВәв”ҳГӨв•ӘГәв”ҳГӨв”ҳГӘв•ӘВәв”ҳГҘ</h1>\n        <p style={{ color: 'var(--color-text-secondary)' }}>\n          в•ӘВ¬в•ӘВЎв”ҳГўв”ҳГ  в”ҳГјв”ҳГЁ в•ӘГәв”ҳГӨв”ҳГӘв•ӘВәв”ҳГҘ в•ӘВәв”ҳГӨв”ҳГ в”ҳГҘв•Әв•Ўв•ӘвҢҗв•ӘГ® в•ӘВәв”ҳГӨв•ӘВ«в•Әв•–в”ҳГӘв•Әв•–в•ӘГ® в”ҳГӘв•ӘВәв”ҳГӨв•ӘВ¬в•ӘГәв•ӘВҪв”ҳГЁв•Әв–’в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВҝв•Әв•Ўв•Әв–’в”ҳГЁв•ӘвҢҗ. в•ӘВәв”ҳГӨв•ӘВ¬в•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’в•ӘВәв•ӘВ¬ в•ӘВ¬в”ҳГ…в•Әв•–в•ӘВҝв”ҳГ© в•Әв•Јв”ҳГҘв•ӘВ» в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ в•ӘГәв”ҳГЁ в•Әв•Ўв”ҳГјв•ӘВЎв•ӘвҢҗ.\n        </p>\n      </div>\n\n      {/* Palette Presets */}\n      <section className=\"space-y-4\">\n        <h2 className=\"text-lg font-black\" style={{ color: 'var(--color-text-primary)' }}>\n          в•ӘГәв”ҳГӨв”ҳГӘв•ӘВәв”ҳГҘ в•ӘВјв•ӘВәв”ҳГ§в•Әв–“в•ӘвҢҗ (Presets)\n        </h2>\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3\">\n          {PRESET_PALETTES.map(p => {\n            const active = p.primary === settings.primary_color && p.accent === settings.accent_color\n            return (\n              <motion.button\n                key={p.label}\n                whileHover={{ scale: 1.02 }}\n                whileTap={{ scale: 0.98 }}\n                onClick={() => applyPreset(p)}\n                className=\"card-glass p-4 text-right transition-all\"\n                style={{\n                  border: active ? `2px solid ${p.primary}` : '2px solid transparent',\n                  boxShadow: active ? `0 0 20px ${p.primary}33` : 'none',\n                }}\n              >\n                <div className=\"flex items-center gap-2 mb-2\">\n                  <div className=\"w-5 h-5 rounded-full\" style={{ background: p.bg, border: '1px solid rgba(255,255,255,0.1)' }} />\n                  <div className=\"w-5 h-5 rounded-full\" style={{ background: p.primary }} />\n                  <div className=\"w-5 h-5 rounded-full\" style={{ background: p.accent }} />\n                  {active && <span className=\"mr-auto text-xs font-bold\" style={{ color: p.primary }}>О“ВЈГҙ в”ҳГҘв•Әв”Өв•Әв•–</span>}\n                </div>\n                <p className=\"text-xs font-bold\" style={{ color: 'var(--color-text-secondary)' }}>{p.label}</p>\n              </motion.button>\n            )\n          })}\n        </div>\n      </section>\n\n      {/* Custom Colors */}\n      <section className=\"space-y-3\">\n        <h2 className=\"text-lg font-black\" style={{ color: 'var(--color-text-primary)' }}>в•ӘВәв”ҳГӨв•ӘГәв”ҳГӨв”ҳГӘв•ӘВәв”ҳГҘ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ«в•Әв•Ўв•Әв•Ўв•ӘвҢҗ</h2>\n        <ColorSwatch label=\"в•ӘВәв”ҳГӨв”ҳГӨв”ҳГӘв”ҳГҘ в•ӘВәв”ҳГӨв•Әв–’в•ӘВӘв”ҳГЁв•Әв”Ӯв”ҳГЁ (Primary)\"  value={settings.primary_color} onChange={v => set('primary_color', v)} />\n        <ColorSwatch label=\"в•ӘВәв”ҳГӨв”ҳГӨв”ҳГӘв”ҳГҘ в•ӘВәв”ҳГӨв•ӘВҪв•ӘВәв”ҳГҘв”ҳГӘв”ҳГЁ (Accent)\"   value={settings.accent_color}  onChange={v => set('accent_color', v)} />\n        <ColorSwatch label=\"в”ҳГӨв”ҳГӘв”ҳГҘ в•ӘВәв”ҳГӨв•ӘВ«в”ҳГӨв”ҳГјв”ҳГЁв•ӘвҢҗ (Background)\" value={settings.bg_color}       onChange={v => set('bg_color', v)} />\n      </section>\n\n      {/* Live Color Preview */}\n      <section>\n        <h2 className=\"text-lg font-black mb-3\" style={{ color: 'var(--color-text-primary)' }}>в”ҳГ в•Әв•Јв•ӘВәв”ҳГЁв”ҳГҘв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘГәв”ҳГӨв”ҳГӘв•ӘВәв”ҳГҘ</h2>\n        <div className=\"rounded-2xl overflow-hidden border\" style={{ borderColor: 'var(--color-border)', backgroundColor: settings.bg_color }}>\n          <div className=\"p-6 space-y-4\">\n            <div className=\"h-10 rounded-xl w-2/3\" style={{ background: `linear-gradient(135deg, ${settings.primary_color}, ${settings.accent_color})` }} />\n            <div className=\"flex gap-3\">\n              <div className=\"h-8 rounded-lg flex-1\" style={{ background: `${settings.primary_color}22`, border: `1px solid ${settings.primary_color}44` }} />\n              <div className=\"h-8 w-24 rounded-lg\" style={{ background: settings.primary_color }} />\n            </div>\n            <div className=\"h-2 rounded-full w-full\" style={{ background: `${settings.accent_color}33` }}>\n              <div className=\"h-2 rounded-full w-1/2\" style={{ background: settings.accent_color }} />\n            </div>\n            <p className=\"text-xs font-mono\" style={{ color: settings.primary_color }}>Primary: {settings.primary_color} в”¬в•– Accent: {settings.accent_color}</p>\n          </div>\n        </div>\n      </section>\n\n      {/* Theme Mode */}\n      <section className=\"space-y-3\">\n        <h2 className=\"text-lg font-black\" style={{ color: 'var(--color-text-primary)' }}>в”ҳГҘв”ҳГ в•Әв•– в•ӘВәв”ҳГӨв”ҳГ в•Әв••в”ҳГ§в•Әв–’ (Theme)</h2>\n        <ThemeSelector value={settings.theme_mode} onChange={v => set('theme_mode', v)} />\n        <p className=\"text-[10px] uppercase tracking-widest font-bold opacity-30 mt-1\">\n          * в•ӘВәв”ҳГӨв”ҳГӘв•Әв•ўв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГӨв”ҳГ©в•ӘВәв•ӘВӘв”ҳГЁ в”ҳГЁв•ӘВ¬в•ӘВҝв•Әв•Ј в•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВјв”ҳГ§в•ӘВәв•Әв–“ в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ \n        </p>\n      </section>\n\n      {/* Font */}\n      <section className=\"space-y-3\">\n        <h2 className=\"text-lg font-black\" style={{ color: 'var(--color-text-primary)' }}>в•ӘВәв”ҳГӨв•ӘВ«в•Әв•– (Font)</h2>\n        <div className=\"card-glass p-4 flex items-center gap-4\">\n          <span className=\"text-2xl\">вүЎЖ’Г¶Гұ</span>\n          <div className=\"flex-1\">\n            <label className=\"label mb-1\">в•ӘВ«в•Әв•– в•ӘВәв”ҳГӨв•ӘВјв•Әв”Ӯв”ҳГ  в•ӘВәв”ҳГӨв•Әв–’в•ӘВӘв”ҳГЁв•Әв”Ӯв”ҳГЁ</label>\n            <select\n              className=\"input\"\n              value={settings.font_body}\n              onChange={e => set('font_body', e.target.value as any)}\n            >\n              {FONTS.map(f => <option key={f} value={f}>{f}</option>)}\n            </select>\n          </div>\n          <p className=\"text-lg font-bold shrink-0\" style={{ fontFamily: settings.font_body, color: 'var(--color-text-secondary)' }}>\n            в•ӘГәв•ӘВҝв•ӘВјв•ӘВ» в”ҳГ§в”ҳГӘв•Әв–“\n          </p>\n        </div>\n      </section>\n\n      {/* Visual Effects */}\n      <section>\n        <h2 className=\"text-lg font-black mb-1\" style={{ color: 'var(--color-text-primary)' }}>в•ӘВәв”ҳГӨв•ӘВ¬в•ӘГәв•ӘВҪв”ҳГЁв•Әв–’в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВҝв•Әв•Ўв•Әв–’в”ҳГЁв•ӘвҢҗ</h2>\n        <div className=\"card-glass px-4\">\n          <Toggle\n            label=\"в•ӘВјв•Әв”Ӯв”ҳГЁв”ҳГ в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв•ӘВ«в”ҳГӨв”ҳГјв”ҳГЁв•ӘвҢҗ (Particles)\"\n            desc=\"в•ӘВ¬в•ӘГәв•ӘВҪв”ҳГЁв•Әв–’ в•ӘВәв”ҳГӨв•ӘВјв•Әв–“в”ҳГЁв•ӘВӘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ¬в•Әв•–в•ӘВәв”ҳГЁв•Әв–’в•ӘвҢҗ в”ҳГјв”ҳГЁ в•ӘВ«в”ҳГӨв”ҳГјв”ҳГЁв•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГјв•ӘВЎв•ӘвҢҗ\"\n            checked={settings.particles_enabled}\n            onChange={v => set('particles_enabled', v)}\n          />\n          <Toggle\n            label=\"в•Әв”Өв•ӘВҝв”ҳГўв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ«в”ҳГӨв”ҳГјв”ҳГЁв•ӘвҢҗ (Grid)\"\n            desc=\"в•ӘВ«в•Әв•–в”ҳГӘв•Әв•– в•ӘВәв”ҳГӨв•Әв”Өв•ӘВҝв”ҳГўв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ«в”ҳГјв”ҳГЁв”ҳГјв•ӘвҢҗ в”ҳГјв”ҳГЁ в•ӘВәв”ҳГӨв•ӘВ«в”ҳГӨв”ҳГјв”ҳГЁв•ӘвҢҗ\"\n            checked={settings.grid_enabled}\n            onChange={v => set('grid_enabled', v)}\n          />\n          <Toggle\n            label=\"в•Әв•–в•ӘВҝв”ҳГ©в•ӘвҢҗ в•ӘВәв”ҳГӨв•Әв•ўв”ҳГӘв•Әв•ўв•ӘВәв•ӘГӯ (Noise Overlay)\"\n            desc=\"в•Әв•–в•ӘВҝв”ҳГ©в•ӘвҢҗ в•ӘВЎв•ӘВҝв”ҳГЁв•ӘВҝв”ҳГЁв•ӘвҢҗ в•ӘВ«в”ҳГјв”ҳГЁв•ӘвҢҗ в•ӘВ¬в•Әв•ўв”ҳГЁв”ҳГј в•Әв•Јв”ҳГ в”ҳГ©в•ӘВәв”ҳГҜ в•ӘВҝв•Әв•Ўв•Әв–’в”ҳГЁв•ӘВәв”ҳГҜ\"\n            checked={settings.noise_enabled}\n            onChange={v => set('noise_enabled', v)}\n          />\n        </div>\n      </section>\n\n      {/* Save */}\n      <button\n        onClick={save}\n        disabled={saving}\n        className=\"btn btn-primary btn-lg w-full\"\n      >\n        {saving ? 'О“Г…в”Ӯ в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•ӘВЎв”ҳГјв•Әв••...' : 'вүЎЖ’ГҶв•ӣ в•ӘВЎв”ҳГјв•Әв•• в•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•Әв••в”ҳГ§в•Әв–’'}\n      </button>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\app\\admin\\categories\\page.tsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\app\\admin\\categories\\page.tsx:36:21\n  34 |     setLoading(false)\n  35 |   }\n> 36 |   useEffect(() => { load() }, [])\n     |                     ^^^^ Avoid calling setState() directly within an effect\n  37 |\n  38 |   function openAdd() { \n  39 |     setForm({ id: `cat-${Date.now()}`, name: '', icon: 'вүЎЖ’ГҙГң', topic_id: topics[0]?.id || '', image_url: '', hide_icon: false })","line":36,"column":21,"nodeType":null,"endLine":36,"endColumn":25},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'load'. Either include it or remove the dependency array.","line":36,"column":31,"nodeType":"ArrayExpression","endLine":36,"endColumn":33,"suggestions":[{"desc":"Update the dependencies array to be: [load]","fix":{"range":[1663,1665],"text":"[load]"}}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":73,"column":21,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":73,"endColumn":24,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[3024,3027],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[3024,3027],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useEffect, useState } from 'react'\r\nimport { motion, AnimatePresence } from 'framer-motion'\r\nimport { createClient } from '@/lib/supabaseClient'\r\nimport toast from 'react-hot-toast'\r\nimport MediaCropEditor, { type CropConfig } from '@/components/MediaCropEditor'\r\nimport { CategoryWithQuestions, AdminCategory } from '@/types/admin'\r\n\r\nconst ICONS = ['вүЎЖ’ГҙГң','вүЎЖ’Г®Г¬','вүЎЖ’Г¶Вј','вүЎЖ’ГҙВЈ','О“Гңв•ң','вүЎЖ’Г„Вј','вүЎЖ’ВәГЎ','вүЎЖ’Г„в•Ў','вүЎЖ’Г¬Г¶','вүЎЖ’Г…ВўвҲ©в••Г…','вүЎЖ’ГҶв•—','О“ВЈГӘвҲ©в••Г…','вүЎЖ’Гүв•ӣ','вүЎЖ’ВәвҢҗ','вүЎЖ’Г„В»']\r\n\r\nexport default function AdminCategoriesPage() {\r\n  const supabase = createClient()\r\n  const [cats, setCats] = useState<CategoryWithQuestions[]>([])\r\n  const [topics, setTopics] = useState<AdminCategory[]>([])\r\n  const [loading, setLoading] = useState(true)\r\n  const [modal, setModal] = useState(false)\r\n  const [editing, setEditing] = useState<CategoryWithQuestions | null>(null)\r\n  const [form, setForm] = useState({ id: '', name: '', icon: 'вүЎЖ’ГҙГң', topic_id: '', image_url: '', hide_icon: false })\r\n  const [saving, setSaving] = useState(false)\r\n  const [uploading, setUploading] = useState(false)\r\n  const [deleteId, setDeleteId] = useState<string | null>(null)\r\n  const [cropEditorUrl, setCropEditorUrl] = useState<string | null>(null)\r\n  const [cropConfig, setCropConfig] = useState<CropConfig | null>(null)\r\n\r\n  async function load() {\r\n    const [catsRes, topicsRes] = await Promise.all([\r\n      supabase.from('categories').select('*, topics(name, color), questions(count)').order('name'),\r\n      supabase.from('topics').select('id, name').order('order_index')\r\n    ])\r\n    \r\n    setCats(catsRes.data ?? [])\r\n    setTopics(topicsRes.data ?? [])\r\n    setLoading(false)\r\n  }\r\n  useEffect(() => { load() }, [])\r\n\r\n  function openAdd() { \r\n    setForm({ id: `cat-${Date.now()}`, name: '', icon: 'вүЎЖ’ГҙГң', topic_id: topics[0]?.id || '', image_url: '', hide_icon: false })\r\n    setEditing(null)\r\n    setModal(true) \r\n  }\r\n  function openEdit(c: CategoryWithQuestions) { \r\n    setForm({ id: c.id, name: c.name, icon: c.icon ?? 'вүЎЖ’ГҙГң', topic_id: c.topic_id || '', image_url: c.image_url || '', hide_icon: c.hide_icon || false })\r\n    setCropConfig(c.crop_config || null)\r\n    setEditing(c)\r\n    setModal(true) \r\n  }\r\n\r\n  async function handleImageUpload(e: React.ChangeEvent<HTMLInputElement>) {\r\n    const file = e.target.files?.[0]\r\n    if (!file) return\r\n\r\n    setUploading(true)\r\n    const fileExt = file.name.split('.').pop()\r\n    const fileName = `${Date.now()}-${Math.random().toString(36).substring(7)}.${fileExt}`\r\n    const filePath = `category_backgrounds/${fileName}`\r\n\r\n    try {\r\n      const { error: uploadError } = await supabase.storage\r\n        .from('images')\r\n        .upload(filePath, file)\r\n\r\n      if (uploadError) throw uploadError\r\n\r\n      const { data } = supabase.storage\r\n        .from('images')\r\n        .getPublicUrl(filePath)\r\n\r\n      setForm(f => ({ ...f, image_url: data.publicUrl }))\r\n      setCropEditorUrl(data.publicUrl)  // Auto-open crop editor after upload\r\n      toast.success('в•ӘВ¬в”ҳГ  в•Әв–’в”ҳГјв•Әв•Ј в•ӘВәв”ҳГӨв•Әв•Ўв”ҳГӘв•Әв–’в•ӘвҢҗ в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ! в•ӘВәв•Әв•ўв•ӘВҝв•Әв•– в•ӘВәв”ҳГӨв”ҳГ©в•Әв•Ў в•ӘВәв”ҳГӨв•ӘГів”ҳГҘ.')\r\n    } catch (error: any) {\r\n      toast.error('в•ӘВ«в•Әв•–в•ӘГә в”ҳГјв”ҳГЁ в•ӘВәв”ҳГӨв•Әв–’в”ҳГјв•Әв•Ј: ' + error.message)\r\n    } finally {\r\n      setUploading(false)\r\n    }\r\n  }\r\n\r\n  async function save() {\r\n    if (!form.name.trim()) { toast.error('в•ӘВәв•Әв”Ӯв”ҳГ  в•ӘВәв”ҳГӨв”ҳГјв•ӘВӘв•ӘвҢҗ в”ҳГ в•Әв•–в”ҳГӨв”ҳГӘв•ӘВҝ'); return }\r\n    setSaving(true)\r\n    const payload = { \r\n      id: form.id,\r\n      name: form.name.trim(), \r\n      icon: form.icon, \r\n      topic_id: form.topic_id || null, \r\n      image_url: form.image_url, \r\n      hide_icon: form.hide_icon,\r\n      crop_config: cropConfig || null\r\n    }\r\n    const { error } = editing\r\n      ? await supabase.from('categories').update(payload).eq('id', editing.id)\r\n      : await supabase.from('categories').insert(payload)\r\n    if (error) { toast.error(error.message); setSaving(false); return }\r\n    toast.success(editing ? 'в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв•ӘВ»в”ҳГЁв•ӘВҪ' : 'в•ӘВ¬в”ҳГ в•ӘВ¬ в•ӘВәв”ҳГӨв•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ')\r\n    setModal(false); setSaving(false); load()\r\n  }\r\n\r\n  async function del(id: string) {\r\n    const { error } = await supabase.from('categories').delete().eq('id', id)\r\n    if (error) { toast.error(error.message); return }\r\n    toast.success('в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•ӘВЎв•Әв–‘в”ҳГј'); setDeleteId(null); load()\r\n  }\r\n\r\n  return (\r\n    <div className=\"p-8\">\r\n      <div className=\"flex items-center justify-between mb-8\">\r\n        <div>\r\n          <h1 className=\"text-3xl font-black gradient-text-primary\">в•ӘВәв”ҳГӨв”ҳГјв•ӘВӘв•ӘВәв•ӘВ¬</h1>\r\n          <p style={{ color: 'var(--color-text-secondary)' }}>{cats.length} в”ҳГјв•ӘВӘв•ӘвҢҗ</p>\r\n        </div>\r\n        <button onClick={openAdd} className=\"btn btn-primary\">+ в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ в”ҳГјв•ӘВӘв•ӘвҢҗ</button>\r\n      </div>\r\n\r\n      {loading ? (\r\n        <div className=\"grid grid-cols-2 md:grid-cols-3 gap-4\">\r\n          {Array(6).fill(0).map((_, i) => <div key={i} className=\"h-28 card-glass animate-shimmer rounded-2xl\" />)}\r\n        </div>\r\n      ) : (\r\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4\">\r\n          {cats.map((c, i) => (\r\n            <motion.div\r\n              key={c.id}\r\n              initial={{ opacity: 0, y: 16 }}\r\n              animate={{ opacity: 1, y: 0 }}\r\n              transition={{ delay: i * 0.05 }}\r\n              className=\"card-glass flex items-center gap-4 relative overflow-hidden\"\r\n            >\r\n              <div className=\"absolute top-0 bottom-0 right-0 w-1 z-10\" style={{ backgroundColor: c.topics?.color || '#3b82f6' }} />\r\n              {c.image_url && (\r\n                <div \r\n                  className=\"absolute inset-0 bg-cover bg-center opacity-30 z-0 pointer-events-none\" \r\n                  style={{ backgroundImage: `url(${c.image_url})` }} \r\n                />\r\n              )}\r\n              <div className=\"text-4xl w-14 h-14 rounded-2xl flex items-center justify-center shrink-0 mr-2 z-10 relative\"\r\n                style={{ background: 'var(--color-surface-3)' }}>\r\n                {c.icon}\r\n              </div>\r\n              <div className=\"flex-1 min-w-0 z-10 relative\">\r\n                <p className=\"font-bold truncate\" style={{ color: 'var(--color-text-primary)' }}>{c.name}</p>\r\n                <div className=\"flex items-center gap-2 mt-1\">\r\n                  {c.topics && (\r\n                    <span className=\"text-[10px] px-2 py-0.5 rounded-md\" style={{ background: `${c.topics.color}20`, color: c.topics.color }}>\r\n                      {c.topics.name}\r\n                    </span>\r\n                  )}\r\n                  <p className=\"text-xs\" style={{ color: 'var(--color-text-muted)' }}>\r\n                    {c.questions?.[0]?.count ?? 0} в•Әв”Ӯв•ӘГұв•ӘВәв”ҳГӨ\r\n                  </p>\r\n                </div>\r\n              </div>\r\n              <div className=\"flex flex-col gap-1\">\r\n                <button onClick={() => openEdit(c)} className=\"btn btn-sm btn-ghost\" style={{ padding: '4px 10px', fontSize: '12px' }}>в•ӘВ¬в•Әв•Јв•ӘВ»в”ҳГЁв”ҳГӨ</button>\r\n                <button onClick={() => setDeleteId(c.id)} className=\"btn btn-sm\" style={{ padding: '4px 10px', fontSize: '12px', background: 'rgba(239,68,68,0.1)', color: '#ef4444', border: '1px solid rgba(239,68,68,0.2)' }}>в•ӘВЎв•Әв–‘в”ҳГј</button>\r\n              </div>\r\n            </motion.div>\r\n          ))}\r\n          {cats.length === 0 && (\r\n            <div className=\"col-span-3 py-16 text-center\" style={{ color: 'var(--color-text-muted)' }}>\r\n              в”ҳГӨв•ӘВә в•ӘВ¬в”ҳГӘв•ӘВјв•ӘВ» в”ҳГјв•ӘВӘв•ӘВәв•ӘВ¬ в•ӘВҝв•Әв•Јв•ӘВ» О“ГҮГ¶ в•ӘГәв•Әв•ўв”ҳГј в”ҳГјв•ӘВӘв•ӘвҢҗ в•ӘВјв•ӘВ»в”ҳГЁв•ӘВ»в•ӘвҢҗ\r\n            </div>\r\n          )}\r\n        </div>\r\n      )}\r\n\r\n      <AnimatePresence>\r\n        {modal && (\r\n          <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}\r\n            className=\"fixed inset-0 z-50 flex items-center justify-center p-4\"\r\n            style={{ background: 'rgba(0,0,0,0.7)' }}\r\n            onClick={() => setModal(false)}>\r\n            <motion.div initial={{ scale: 0.9, y: 20 }} animate={{ scale: 1, y: 0 }} exit={{ scale: 0.9 }}\r\n              className=\"card-glass w-full max-w-sm p-8 space-y-5\"\r\n              onClick={e => e.stopPropagation()}>\r\n              <h2 className=\"text-xl font-bold\" style={{ color: 'var(--color-text-primary)' }}>\r\n                {editing ? 'в•ӘВ¬в•Әв•Јв•ӘВ»в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГјв•ӘВӘв•ӘвҢҗ' : 'в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ в”ҳГјв•ӘВӘв•ӘвҢҗ в•ӘВјв•ӘВ»в”ҳГЁв•ӘВ»в•ӘвҢҗ'}\r\n              </h2>\r\n              \r\n              <div>\r\n                <label className=\"label\">в•ӘВәв•Әв”Ӯв”ҳГ  в•ӘВәв”ҳГӨв”ҳГјв•ӘВӘв•ӘвҢҗ *</label>\r\n                <input className=\"input\" value={form.name} onChange={e => setForm(f => ({ ...f, name: e.target.value }))} placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в•ӘВјв•Әв•‘в•Әв–’в•ӘВәв”ҳГјв”ҳГЁв•ӘВә\" />\r\n              </div>\r\n\r\n              {!editing && (\r\n                <div>\r\n                  <label className=\"label\">в•ӘВәв”ҳГӨв”ҳГ в•Әв•Јв•Әв–’в”ҳГј (ID)</label>\r\n                  <input className=\"input\" value={form.id} onChange={e => setForm(f => ({ ...f, id: e.target.value }))} placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: cat-geography\" />\r\n                  <p className=\"text-[10px] text-white/50 mt-1\">в”ҳГЁв•ӘВ¬в”ҳГ  в•ӘВ¬в”ҳГӘв”ҳГӨв”ҳГЁв•ӘВ»в”ҳГ§ в•ӘВ¬в”ҳГӨв”ҳГ©в•ӘВәв•ӘВӘв”ҳГЁв•ӘВәв”ҳГҜв•ӘГ® в”ҳГЁв”ҳГ в”ҳГўв”ҳГҘв”ҳГў в•ӘВ¬в•Әв•Јв•ӘВ»в”ҳГЁв”ҳГӨв”ҳГ§ в•ӘГ‘в•Әв–‘в•ӘВә в•ӘГәв•Әв–’в•ӘВ»в•ӘВ¬.</p>\r\n                </div>\r\n              )}\r\n\r\n              <div>\r\n                <label className=\"label\">в•ӘВәв”ҳГӨв”ҳГ в”ҳГӘв•Әв•ўв”ҳГӘв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВәв•ӘВҝв•Әв•Ј в”ҳГӨв”ҳГ§</label>\r\n                <select className=\"input\" value={form.topic_id} onChange={e => setForm(f => ({ ...f, topic_id: e.target.value }))}>\r\n                  <option value=\"\">в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в”ҳГ в”ҳГӘв•Әв•ўв”ҳГӘв•Әв•Ј</option>\r\n                  {topics.map(t => (\r\n                    <option key={t.id} value={t.id}>{t.name}</option>\r\n                  ))}\r\n                </select>\r\n              </div>\r\n\r\n              {/* Image Upload + Crop Button */}\r\n              <div>\r\n                <label className=\"label\">в•Әв•Ўв”ҳГӘв•Әв–’в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ«в”ҳГӨв”ҳГјв”ҳГЁв•ӘвҢҗ (в•ӘВәв•ӘВ«в•ӘВ¬в”ҳГЁв•ӘВәв•Әв–’в”ҳГЁ)</label>\r\n                <div className=\"flex flex-col gap-3\">\r\n                  <input className=\"input\" value={form.image_url} onChange={e => setForm(f => ({ ...f, image_url: e.target.value }))} placeholder=\"в•Әв–’в•ӘВәв•ӘВҝв•Әв•– в”ҳГ в•ӘВҝв•ӘВәв•Әв”Өв•Әв–’ в”ҳГӨв”ҳГӨв•Әв•Ўв”ҳГӘв•Әв–’в•ӘвҢҗ (JPG/PNG)\" />\r\n                  <div className=\"relative\">\r\n                    <input \r\n                      type=\"file\" \r\n                      accept=\"image/*\" \r\n                      onChange={handleImageUpload} \r\n                      disabled={uploading} \r\n                      className=\"block w-full text-sm text-white/50 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-bold file:bg-blue-500/20 file:text-blue-300 hover:file:bg-blue-500/30 transition-all cursor-pointer disabled:opacity-50\"\r\n                    />\r\n                    {uploading && <div className=\"absolute right-4 top-2 text-xs text-cyan-400 animate-pulse font-bold\">в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•Әв–’в”ҳГјв•Әв•Ј...</div>}\r\n                  </div>\r\n                  {form.image_url && (\r\n                    <button\r\n                      type=\"button\"\r\n                      onClick={() => setCropEditorUrl(form.image_url)}\r\n                      className=\"w-full py-2 rounded-xl border border-purple-500/30 bg-purple-500/10 text-purple-300 text-sm font-bold hover:bg-purple-500/20 transition-colors flex items-center justify-center gap-2\"\r\n                    >\r\n                      О“ВЈГ©вҲ©в••Г… в•Әв•ўв•ӘВҝв•Әв•– в•ӘВәв”ҳГӨв”ҳГ©в•Әв•Ў в”ҳГӘв•ӘВәв”ҳГӨв•ӘВ¬в”ҳГўв•ӘВҝв”ҳГЁв•Әв–’\r\n                      {cropConfig && <span className=\"text-xs bg-green-500/20 text-green-400 px-2 py-0.5 rounded-full\">в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•Әв•ўв•ӘВҝв•Әв•– О“ВЈГҙ</span>}\r\n                    </button>\r\n                  )}\r\n                </div>\r\n              </div>\r\n\r\n              <div>\r\n                <label className=\"label\">в•ӘВәв”ҳГӨв•ӘГәв”ҳГЁв”ҳГ©в”ҳГӘв”ҳГҘв•ӘвҢҗ (Emoji)</label>\r\n                <div className=\"flex flex-wrap gap-2 mt-2\">\r\n                  {ICONS.map(icon => (\r\n                    <button key={icon} onClick={() => setForm(f => ({ ...f, icon }))}\r\n                      className=\"w-10 h-10 rounded-xl text-xl flex items-center justify-center transition-all\"\r\n                      style={{ background: form.icon === icon ? 'var(--color-primary)' : 'var(--color-surface-3)', transform: form.icon === icon ? 'scale(1.15)' : 'scale(1)' }}>\r\n                      {icon}\r\n                    </button>\r\n                  ))}\r\n                </div>\r\n                <div className=\"mt-4 flex items-center gap-3 bg-white/5 p-3 rounded-xl border border-white/10\">\r\n                  <input \r\n                    type=\"checkbox\" \r\n                    id=\"hideIcon\"\r\n                    checked={form.hide_icon} \r\n                    onChange={e => setForm(f => ({ ...f, hide_icon: e.target.checked }))} \r\n                    className=\"w-5 h-5 accent-purple-500 rounded bg-black/50 border-white/20\"\r\n                  />\r\n                  <label htmlFor=\"hideIcon\" className=\"text-sm font-bold text-white/80 cursor-pointer select-none\">\r\n                    в•ӘГ‘в•ӘВ«в”ҳГјв•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв•ӘГәв”ҳГЁв”ҳГ©в”ҳГӘв”ҳГҘв•ӘвҢҗ в”ҳГјв”ҳГЁ в•Әв•Ўв”ҳГјв•ӘВЎв•ӘвҢҗ в•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в•ӘВәв”ҳГӨв”ҳГӨв•Әв•Јв•ӘВҝв•ӘвҢҗ\r\n                  </label>\r\n                </div>\r\n              </div>\r\n              <div className=\"flex gap-3 pt-2\">\r\n                <button onClick={save} disabled={saving} className=\"btn btn-primary flex-1\">\r\n                  {saving ? 'в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•ӘВЎв”ҳГјв•Әв••...' : editing ? 'в•ӘВЎв”ҳГјв•Әв••' : 'в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ'}\r\n                </button>\r\n                <button onClick={() => setModal(false)} className=\"btn btn-ghost\">в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ</button>\r\n              </div>\r\n            </motion.div>\r\n          </motion.div>\r\n        )}\r\n      </AnimatePresence>\r\n\r\n      <AnimatePresence>\r\n        {deleteId && (\r\n          <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}\r\n            className=\"fixed inset-0 z-50 flex items-center justify-center p-4\"\r\n            style={{ background: 'rgba(0,0,0,0.7)' }}>\r\n            <motion.div initial={{ scale: 0.9 }} animate={{ scale: 1 }} exit={{ scale: 0.9 }}\r\n              className=\"card-glass p-8 max-w-sm w-full text-center space-y-5\">\r\n              <div className=\"text-5xl\">вүЎЖ’Г№ГҰвҲ©в••Г…</div>\r\n              <h3 className=\"text-xl font-bold\" style={{ color: 'var(--color-text-primary)' }}>в•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ» в•ӘВәв”ҳГӨв•ӘВЎв•Әв–‘в”ҳГј</h3>\r\n              <p style={{ color: 'var(--color-text-secondary)' }}>в•Әв”Ӯв”ҳГЁв•ӘВ¬в”ҳГ  в•ӘВЎв•Әв–‘в”ҳГј в•ӘВәв”ҳГӨв”ҳГјв•ӘВӘв•ӘвҢҗ в”ҳГӘв•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•ӘГәв•Әв”Ӯв•ӘВӘв”ҳГӨв•ӘВ¬в”ҳГ§в•ӘВә в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в•ӘВ¬в•ӘВҝв•Әв•–в•ӘвҢҗ.</p>\r\n              <div className=\"flex gap-3\">\r\n                <button onClick={() => del(deleteId)} className=\"btn flex-1\" style={{ background: 'rgba(239,68,68,0.15)', color: '#ef4444', border: '1px solid rgba(239,68,68,0.3)' }}>в”ҳГҘв•Әв•Јв”ҳГ в•ӘГ® в•ӘВәв•ӘВЎв•Әв–‘в”ҳГј</button>\r\n                <button onClick={() => setDeleteId(null)} className=\"btn btn-ghost flex-1\">в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ</button>\r\n              </div>\r\n            </motion.div>\r\n          </motion.div>\r\n        )}\r\n      </AnimatePresence>\r\n\r\n      {/* Crop Editor Modal */}\r\n      <AnimatePresence>\r\n        {cropEditorUrl && (\r\n          <MediaCropEditor\r\n            mediaUrl={cropEditorUrl}\r\n            mediaType=\"image\"\r\n            initialConfig={cropConfig ?? undefined}\r\n            availableSlots={['cat_setup', 'cat_game']}\r\n            onSave={(cfg) => {\r\n              setCropConfig(cfg)\r\n              setCropEditorUrl(null)\r\n              toast.success('в•ӘВ¬в”ҳГ  в•ӘВЎв”ҳГјв•Әв•• в•ӘГ‘в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ©в•Әв•Ў')\r\n            }}\r\n            onClose={() => setCropEditorUrl(null)}\r\n          />\r\n        )}\r\n      </AnimatePresence>\r\n    </div>\r\n  )\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\app\\admin\\feedback\\page.tsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\app\\admin\\feedback\\page.tsx:29:5\n  