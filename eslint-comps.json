el>\r\n                <textarea className=\"input min-h-[80px]\" placeholder='в•ӘВәв”ҳГӨв”ҳГҘв•Әв•Ў в•ӘВәв”ҳГӨв•Әв–‘в”ҳГЁ в•Әв”Ӯв”ҳГЁв”ҳГ©в•Әв–’в•ӘГәв”ҳГ§ в•ӘВәв”ҳГӨв”ҳГҮ TTS в”ҳГјв”ҳГЁ в•ӘВЎв•ӘВәв”ҳГӨ в•Әв•Јв•ӘВ»в”ҳГ  в”ҳГӘв•ӘВјв”ҳГӘв•ӘВ» в”ҳГ в”ҳГӨв”ҳГј в•Әв•Ўв”ҳГӘв•ӘВ¬в”ҳГЁ...' value={newPhrase.text} onChange={e => setNewPhrase({ ...newPhrase, text: e.target.value })} />\r\n              </div>\r\n              <div>\r\n                <label className=\"label flex items-center justify-between\">\r\n                  <span>в”ҳГ в”ҳГӨв”ҳГј в•Әв•Ўв”ҳГӘв•ӘВ¬в”ҳГЁ (в•ӘВәв•ӘВ«в•ӘВ¬в”ҳГЁв•ӘВәв•Әв–’в”ҳГЁ)</span>\r\n                  {phraseAudioFile && <span className=\"text-xs text-green-400\">в•ӘВ¬в”ҳГ  в•ӘВәв•ӘВ«в•ӘВ¬в”ҳГЁв•ӘВәв•Әв–’ в•ӘВәв”ҳГӨв”ҳГ в”ҳГӨв”ҳГј О“ВЈГҙ</span>}\r\n                </label>\r\n                <input type=\"file\" accept=\"audio/*\" className=\"input text-sm file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-bold file:bg-primary/20 file:text-primary hover:file:bg-primary/30\" onChange={e => setPhraseAudioFile(e.target.files?.[0] || null)} />\r\n              </div>\r\n              <div className=\"flex gap-4 pt-2\">\r\n                <button onClick={addPhrase} disabled={uploadingAudio} className=\"btn btn-primary flex-1\">{uploadingAudio ? 'в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•Әв–’в”ҳГјв•Әв•Ј...' : 'в•ӘГ‘в•Әв•ўв•ӘВәв”ҳГјв•ӘвҢҗ'}</button>\r\n                <button onClick={() => { setShowAddModal(false); setPhraseAudioFile(null) }} className=\"btn btn-ghost\">в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ</button>\r\n              </div>\r\n            </motion.div>\r\n          </motion.div>\r\n        )}\r\n      </AnimatePresence>\r\n\r\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶