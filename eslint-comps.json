                 generatingId === cat.id \r\n                    ? 'bg-white/10 text-white/50 cursor-not-allowed'\r\n                    : 'bg-white text-black hover:scale-[1.02] active:scale-[0.98]'\r\n                }`}\r\n              >\r\n                {generatingId === cat.id ? (\r\n                  <>\r\n                    <div className=\"w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin\" />\r\n                    в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГӘв”ҳГӨв”ҳГЁв•ӘВ»...\r\n                  </>\r\n                ) : (\r\n                  <>\r\n                    <span>вүЎЖ’ГұГ»</span>\r\n                    {questions.length === 0 ? 'в•ӘВ¬в”ҳГӘв”ҳГӨв”ҳГЁв•ӘВ» в•ӘГәв”ҳГӘв”ҳГӨв”ҳГЁ' : 'в•ӘВ¬в”ҳГӘв”ҳГӨв”ҳГЁв•ӘВ» в•ӘВәв”ҳГӨв”ҳГ в•Әв–“в”ҳГЁв•ӘВ»'}\r\n                  </>\r\n                )}\r\n              </button>\r\n            </div>\r\n          )\r\n        })}\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\app\\admin\\landing\\page.tsx","messages":[],"suppressedMessages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'supabase'. Either include it or remove the dependency array.","line":74,"column":6,"nodeType":"ArrayExpression","endLine":74,"endColumn":8,"suggestions":[{"desc":"Update the dependencies array to be: [supabase]","fix":{"range":[2914,2916],"text":"[supabase]"}}],"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Karam\\Downloads\\abu-al-areef-trivia-main (1)\\abu-al-areef-trivia-main\\app\\admin\\layout.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRule