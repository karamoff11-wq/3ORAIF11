ӘВәв•ӘВ¬в•ӘВј в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв”ҳГӨв”ҳГЁ',        icon: 'вүЎЖ’ГҙГЁ' },\n  { id: 'cat-companies',      topic_id: 'topic-economy',   name: 'в•Әв”Өв•Әв–’в”ҳГўв•ӘВәв•ӘВ¬',               icon: 'вүЎЖ’Г…Гі' },\n  { id: 'cat-trade',          topic_id: 'topic-economy',   name: 'в•Әв•Ўв•ӘВәв•ӘВ»в•Әв–’в•ӘВәв•ӘВ¬ в”ҳГӘв•ӘВ¬в•ӘВјв•ӘВәв•Әв–’в•ӘвҢҗ',        icon: 'вүЎЖ’ГңГі' },\n  { id: 'cat-stadiums',       topic_id: 'topic-football',  name: 'в”ҳГ в”ҳГӨв•ӘВәв•Әв•Јв•ӘВҝ',               icon: 'вүЎЖ’Г…Ж’вҲ©в••Г…' },\n  { id: 'cat-careers',        topic_id: 'topic-football',  name: 'в”ҳГ в•Әв”Ӯв”ҳГЁв•Әв–’в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГӨв•ӘВәв•Әв•Јв•ӘВҝв”ҳГЁв”ҳГҘ',      icon: 'вүЎЖ’Г…Гў' },\n  { id: 'cat-guess-team',     topic_id: 'topic-football',  name: 'в•ӘВ«в”ҳГ в”ҳГҘ в•ӘВәв”ҳГӨв”ҳГјв•Әв–’в”ҳГЁв”ҳГ©',           icon: 'вүЎЖ’ГҰГІ' },\n  { id: 'cat-logos',          topic_id: 'topic-football',  name: 'в•Әв”Өв•Әв•Јв•ӘВәв•Әв–’в•ӘВәв•ӘВ¬ в”ҳГ©в•ӘВ»в”ҳГЁв”ҳГ в•ӘвҢҗ',         icon: 'вүЎЖ’ВўГӯвҲ©в••Г…' },\n  { id: 'cat-general-know',   topic_id: 'topic-general',   name: 'в”ҳГ в•Әв•Јв”ҳГӨв”ҳГӘв”ҳГ в•ӘВәв•ӘВ¬ в•Әв•Јв•ӘВәв”ҳГ в•ӘвҢҗ',         icon: 'вүЎЖ’ВәГЎ' },\n  { id: 'cat-food',           topic_id: 'topic-general',   name: 'в•Әв•–в•Әв•Јв•ӘВәв”ҳГ ',                icon: 'вүЎЖ’Г¬ГІ' },\n  { id: 'cat-art',            topic_id: 'topic-general',   name: 'в”ҳГјв”ҳГҘв”ҳГӘв”ҳГҘ',                icon: 'вүЎЖ’Г„Вҝ' },\n  { id: 'cat-history',        topic_id: 'topic-general',   name: 'в•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ«',               icon: 'вүЎЖ’ГҙВЈ' },\n  { id: 'cat-movie-titanic',  topic_id: 'topic-movies',    name: 'Titanic',              icon: 'вүЎЖ’ГңГі' },\n  { id: 'cat-movie-inception',topic_id: 'topic-movies',    name: 'Inception',            icon: 'вүЎЖ’Г®ГҮ' },\n  { id: 'cat-movie-dk',       topic_id: 'topic-movies',    name: 'The Dark Knight',      icon: 'вүЎЖ’ВӘГ§' },\n  { id: 'cat-movie-avatar',   topic_id: 'topic-movies',    name: 'Avatar',               icon: 'вүЎЖ’Г®в–“' },\n  { id: 'cat-movi