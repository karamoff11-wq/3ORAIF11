neratorCategory[]>([])\r\n  const [isLoading, setIsLoading] = useState(true)\r\n  const [generatingId, setGeneratingId] = useState<string | null>(null)\r\n  const supabase = createClient()\r\n\r\n  const loadData = async () => {\r\n    setIsLoading(true)\r\n    // Fetch categories with topic info and difficulty breakdown\r\n    const { data: categories } = await supabase.from('categories').select(`\r\n      id,\r\n      name,\r\n      topics (name, color),\r\n      questions (id, difficulty)\r\n    `)\r\n    \r\n    setData(categories || [])\r\n    setIsLoading(false)\r\n  }\r\n\r\n  useEffect(() => {\r\n    loadData()\r\n  }, [])\r\n\r\n  const handleGenerate = async (cat: GeneratorCategory) => {\r\n    setGeneratingId(cat.id)\r\n    try {\r\n      const res = await fetch('/api/admin/generate', {\r\n        method: 'POST',\r\n        headers: {\r\n          'Content-Type': 'application/json'\r\n        },\r\n        body: JSON.stringify({\r\n          sessionId: 'pre-seed', // Used for admin pre-seeding\r\n          teams: 2, // Default for generation batch\r\n          categories: [cat.id, cat.id, cat.id, cat.id, cat.id, cat.id] // Batch for this category\r\n        })\r\n      })\r\n      \r\n      const result = await res.json()\r\n      if (res.ok) {\r\n        toast.success(result.message || `в•ӘВ¬в”ҳГ  в•ӘВ¬в”ҳГӘв”ҳГӨв”ҳГЁв•ӘВ» ${result.count} в•Әв”Ӯв•ӘГұв•ӘВәв”ҳГӨ в”ҳГӨв”ҳГӨв”ҳГјв•ӘВӘв•ӘвҢҗ: ${cat.name}`)\r\n        loadData()\r\n      } else {\r\n        throw new Error(result.error || 'в”ҳГјв•Әв”Өв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГӘв”ҳГӨв”ҳГЁв•ӘВ»')\r\n      }\r\n    } catch (error: any) {\r\n      toast.error('в•ӘВ«в•Әв•–в•ӘГә: ' + error.message)\r\n    } finally {\r\n      setGeneratingId(null)\r\n    }\r\n  }\r\n\r\n  if (isLoading) return <div className=\"p-12 text-center loud-label\">в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в”ҳГјв•ӘВЎв•Әв•Ў в•ӘВәв”ҳГӨв”ҳГҘв•Әв••в•ӘВәв”ҳГ ...</div>\r\n\r\n  const getHealthStatus = (count: number) => {\r\n    if (count === 0) return { label: 'в”ҳГј